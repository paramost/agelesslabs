{# ── Page ─────────────────────────────────────────────────────────────────── #}

<div class="bm-wrap">

  {# ── Main column ──────────────────────────────────────────────────────── #}
  <main class="bm-main">

    {# Breadcrumb #}
    <nav class="bm-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="bm-breadcrumb-sep">›</span>
      <a href="/biomarkers">Biomarkers</a>
      <span class="bm-breadcrumb-sep">›</span>
      <span class="bm-breadcrumb-current">{{ biomarker }}</span>
    </nav>

    {# Category + heading #}
    <div class="bm-heading">
      {% if category %}<span class="bm-category-pill">{{ category }}</span>{% endif %}
      <h1 class="bm-title">{{ biomarker }}</h1>
      {% if also_known_as %}<div class="bm-aka">Also known as: {{ also_known_as }}</div>{% endif %}
    </div>

    {# Meta bar — published / reviewed / author / reviewer #}
    <div class="bm-meta" role="complementary" aria-label="Article metadata">
      <div class="bm-meta-item">
        Published <strong>{{ date_published }}</strong>
      </div>
      <span class="bm-meta-dot"></span>
      <div class="bm-meta-item">
        Reviewed <strong>{{ date_reviewed }}</strong>
      </div>
      <span class="bm-meta-dot"></span>
      <div class="bm-meta-item">
        By <strong>{{ author_name }}</strong>
      </div>
      {% if reviewer_name %}
      <span class="bm-meta-dot"></span>
      <div class="bm-meta-item">
        Reviewed by <strong>{{ reviewer_name }}{% if reviewer_credentials %}, {{ reviewer_credentials }}{% endif %}</strong>
      </div>
      {% endif %}
    </div>

    {# Inline disclaimer #}
    <p class="bm-disclaimer-inline">
      For informational purposes only — not medical advice.
      Always consult a qualified healthcare provider before making changes to your health regimen.
      <a href="/disclaimer">Full disclaimer →</a>
    </p>

    {# Definition box #}
    {% if definition %}
    <aside class="bm-definition" aria-label="Definition">
      <div class="bm-definition-label">What is {{ biomarker }}?</div>
      <dl>
        <dt>{{ biomarker }}{% if also_known_as %} ({{ also_known_as }}){% endif %}</dt>
        <dd>{{ definition }}</dd>
        {% if why_it_matters %}
        <dt>Why it matters for longevity</dt>
        <dd>{{ why_it_matters }}</dd>
        {% endif %}
      </dl>
    </aside>
    {% endif %}

    {# Key Takeaways #}
    {% if takeaways and takeaways.length %}
    <div class="bm-takeaways">
      <div class="bm-takeaways-label">Key Takeaways</div>
      <ul>
        {% for item in takeaways %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── Article prose — written per page ─────────────────────────────── #}
    {{ content | safe }}

    {# Ranges table #}
    {% if standard_range or longevity_optimal %}
    <div class="bm-ranges">
      <div class="bm-ranges-label">{{ biomarker }} Reference Ranges</div>
      <table class="bm-table" role="table" aria-label="{{ biomarker }} reference ranges">
        <thead>
          <tr>
            <th scope="col">Range Type</th>
            <th scope="col">Value{% if standard_unit %} ({{ standard_unit }}){% endif %}</th>
            <th scope="col">Notes</th>
          </tr>
        </thead>
        <tbody>
          {% if standard_range %}
          <tr>
            <td>Standard Clinical Range</td>
            <td>{{ standard_range }}</td>
            <td>Designed to identify disease risk — not longevity optimisation.</td>
          </tr>
          {% endif %}
          {% if longevity_optimal %}
          <tr>
            <td>Longevity-Optimal Target</td>
            <td class="td-optimal">{{ longevity_optimal }}</td>
            <td>
              Associated with reduced all-cause mortality and extended healthspan.
              {% if longevity_notes %}<div class="td-note">{{ longevity_notes }}</div>{% endif %}
            </td>
          </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {# Inline tool CTA #}
    <div class="bm-tool-cta">
      <p>Already have your results? See what your <em>{{ biomarker }}</em> and other markers reveal about your longevity in 60 seconds.</p>
      <a href="/analyze">Analyze My Labs →</a>
    </div>

    {# Recommended tests — affiliate #}
    {% if affiliate_tests and affiliate_tests.length %}
    <div class="bm-tests">
      <div class="bm-tests-label">Where to Test {{ biomarker }}</div>
      <div class="bm-tests-grid">
        {% for test in affiliate_tests %}
        <a href="{{ test.url }}" target="_blank" rel="noopener sponsored" class="bm-test-card">
          {% if test.badge %}<span class="bm-test-badge">{{ test.badge }}</span>{% endif %}
          <div class="bm-test-name">{{ test.name }}</div>
          <div class="bm-test-note">{{ test.note }}</div>
          <div class="bm-test-link">Learn more →</div>
        </a>
        {% endfor %}
      </div>
      <p class="bm-affiliate-disclosure">Affiliate disclosure: we may earn a commission if you purchase through these links at no extra cost to you.</p>
    </div>
    {% endif %}

    {# FAQ #}
    {% if faqs and faqs.length %}
    <div class="bm-faq">
      <div class="bm-faq-label">Frequently Asked Questions</div>
      {% for faq in faqs %}
      <div class="bm-faq-item">
        <h3>{{ faq.question }}</h3>
        <p>{{ faq.answer }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# Author block #}
    <div class="bm-author">
      <div class="bm-author-avatar" aria-hidden="true">
        {{ author_name | truncate(2, true, '') | upper }}
      </div>
      <div class="bm-author-meta">
        <div class="bm-author-role">Written by</div>
        <div class="bm-author-name">{{ author_name }}</div>
        <div class="bm-author-title">{{ author_title }} · <a href="/about" style="color:var(--text-muted);text-decoration:underline;font-size:11px;">About AgelessLabs</a></div>
      </div>
    </div>
    {% if reviewer_name %}
    <div class="bm-author">
      <div class="bm-author-avatar" aria-hidden="true">
        {{ reviewer_name | truncate(2, true, '') | upper }}
      </div>
      <div class="bm-author-meta">
        <div class="bm-author-role">Medically reviewed by</div>
        <div class="bm-author-name">{{ reviewer_name }}</div>
        {% if reviewer_credentials %}<div class="bm-author-title">{{ reviewer_credentials }}</div>{% endif %}
      </div>
    </div>
    {% endif %}

  </main>

  {# ── Sidebar ───────────────────────────────────────────────────────────── #}
  <aside class="bm-sidebar" aria-label="Quick reference">

    {# At-a-glance range card #}
    <div class="bm-sidebar-card">
      <div class="bm-sidebar-label">{{ biomarker }} at a Glance</div>
      <div>
        {% if standard_range %}
        <div class="bm-range-item">
          <span class="bm-range-key">Standard</span>
          <span class="bm-range-val">{{ standard_range }}</span>
        </div>
        {% endif %}
        {% if longevity_optimal %}
        <div class="bm-range-item">
          <span class="bm-range-key">Longevity target</span>
          <span class="bm-range-val optimal">{{ longevity_optimal }}</span>
        </div>
        {% endif %}
        {% if standard_unit %}
        <div class="bm-range-item">
          <span class="bm-range-key">Unit</span>
          <span class="bm-range-val">{{ standard_unit }}</span>
        </div>
        {% endif %}
        {% if category %}
        <div class="bm-range-item">
          <span class="bm-range-key">Category</span>
          <span class="bm-range-val">{{ category }}</span>
        </div>
        {% endif %}
      </div>
    </div>

    {# Analyze CTA — sidebar #}
    <div class="bm-sidebar-card" style="background:rgba(181,201,160,0.03);border-color:rgba(181,201,160,0.2);">
      <div class="bm-sidebar-label">Have your labs?</div>
      <p style="font-size:13px;color:var(--text-dim);line-height:1.6;margin-bottom:14px;">See how your {{ biomarker }} compares — get a full longevity analysis in 60 seconds.</p>
      <a href="/analyze" class="btn-primary" style="font-size:11px;padding:10px 16px;display:block;text-align:center;">Analyze My Labs →</a>
    </div>

    {# Related biomarkers — populated per page via frontmatter #}
    {% if related_biomarkers and related_biomarkers.length %}
    <div class="bm-sidebar-card">
      <div class="bm-sidebar-label">Related Biomarkers</div>
      <div class="bm-related-links">
        {% for rel in related_biomarkers %}
        <a href="{{ rel.url }}" class="bm-related-link">
          {{ rel.name }}
          <span class="bm-related-link-arrow">→</span>
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

  </aside>

</div>
