{#
================================================================================
  BIOMARKER PAGE TEMPLATE — agelesslabs.ai
  Layout: src/_includes/biomarker.njk
  Usage: Individual biomarker pages use `layout: biomarker.njk` in frontmatter

  REQUIRED FRONTMATTER
  ─────────────────────
  layout:           biomarker.njk
  title:            "ApoB — Optimal Levels, Longevity Range & How to Lower It | agelesslabs.ai"
  description:      "Meta description — 150-160 chars, optimised for CTR and AI extraction."
  biomarker:        "ApoB"                         ← display name used in headings
  also_known_as:    "Apolipoprotein B"              ← shown in definition box; omit if none
  category:         "Cardiovascular"               ← Cardiovascular | Metabolic | Inflammation | Hormonal | Nutrients
  url_path:         "/biomarkers/apob"             ← canonical path, no trailing slash

  date_published:   "2026-04-15"                   ← ISO 8601
  date_modified:    "2026-04-15"
  date_reviewed:    "2026-04-15"

  author_name:      "Dan Carey"
  author_title:     "Founder, AgelessLabs"
  reviewer_name:    ""                             ← leave blank until reviewer is secured
  reviewer_credentials: ""                         ← e.g. "MD, Preventive Medicine"

  definition:       "One or two sentences defining the biomarker."
  why_it_matters:   "One or two sentences on why this marker matters for longevity."

  standard_range:   "< 130 mg/dL"                 ← clinical standard range as a string
  longevity_optimal: "< 80 mg/dL"                 ← longevity-optimised target
  longevity_notes:  "Optional note on longevity range, e.g. expert targets."
  standard_unit:    "mg/dL"

  takeaways:                                       ← 3–5 bullets; shown near top and in schema
    - "First key takeaway."
    - "Second key takeaway."
    - "Third key takeaway."

  affiliate_tests:                                 ← omit array items that don't carry this marker
    - name:   "Ulta Lab Tests"
      url:    "https://www.ultalabtests.com/partners/agelesslabs/..."
      note:   "Order à la carte — no doctor's visit. Results in 24–48 hours."
      badge:  "À la Carte"
    - name:   "Function Health"
      url:    "https://www.functionhealth.com"
      note:   "Included in their comprehensive 100+ marker annual panel."
      badge:  "Comprehensive"

  faqs:                                            ← minimum 3; match FAQPage schema below
    - question: "What is a good [biomarker] level for longevity?"
      answer:   "Self-contained answer, 40–60 words."
    - question: "Second question?"
      answer:   "Self-contained answer."
    - question: "Third question?"
      answer:   "Self-contained answer."

  PAGE BODY (between frontmatter and end of file)
  ────────────────────────────────────────────────
  Write the article prose as HTML. Suggested sections:

    <section class="bm-section">
      <h2>Why {{ biomarker }} matters for longevity</h2>
      <p>...</p>
    </section>

    <section class="bm-section">
      <h2>What moves {{ biomarker }}?</h2>
      <p>...</p>
    </section>

    <section class="bm-section">
      <h2>How often should you test {{ biomarker }}?</h2>
      <p>...</p>
    </section>

  The template renders the definition box, key takeaways, ranges table,
  inline tool CTA, affiliate cards, FAQ, and author block automatically.
  You only write the prose.
================================================================================
#}

{# ── JSON-LD Schema ───────────────────────────────────────────────────────── #}
{# NOTE: Ideally injected into <head>. Until base.njk has a headContent hook,  #}
{# Google supports JSON-LD anywhere in the document — this is fully valid.     #}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalWebPage",
      "@id": "https://agelesslabs.ai{{ url_path }}",
      "url": "https://agelesslabs.ai{{ url_path }}",
      "name": {{ title | dump | safe }},
      "description": {{ description | dump | safe }},
      "datePublished": "{{ date_published }}",
      "dateModified": "{{ date_modified }}",
      "lastReviewed": "{{ date_reviewed }}",
      "medicalAudience": {
        "@type": "MedicalAudience",
        "audienceType": "Patient"
      },
      "author": {
        "@type": "Person",
        "name": "{{ author_name }}",
        "jobTitle": "{{ author_title }}",
        "url": "https://agelesslabs.ai/about"
      },
      "publisher": {
        "@type": "Organization",
        "name": "AgelessLabs",
        "url": "https://agelesslabs.ai",
        "logo": {
          "@type": "ImageObject",
          "url": "https://agelesslabs.ai/og-image.png"
        }
      },
      "mainEntityOfPage": "https://agelesslabs.ai{{ url_path }}"
    },
    {
      "@type": "Article",
      "headline": {{ title | dump | safe }},
      "description": {{ description | dump | safe }},
      "datePublished": "{{ date_published }}",
      "dateModified": "{{ date_modified }}",
      "author": {
        "@type": "Person",
        "name": "{{ author_name }}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "AgelessLabs",
        "logo": {
          "@type": "ImageObject",
          "url": "https://agelesslabs.ai/og-image.png"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://agelesslabs.ai"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Biomarkers",
          "item": "https://agelesslabs.ai/biomarkers"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ biomarker }}",
          "item": "https://agelesslabs.ai{{ url_path }}"
        }
      ]
    }{% if faqs and faqs.length %},
    {
      "@type": "FAQPage",
      "mainEntity": [{% for faq in faqs %}
        {
          "@type": "Question",
          "name": {{ faq.question | dump | safe }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ faq.answer | dump | safe }}
          }
        }{% if not loop.last %},{% endif %}{% endfor %}
      ]
    }{% endif %}
  ]
}
</script>

<style>
  /* ── Biomarker page layout ─────────────────────────────────────────────── */

  .bm-wrap {
    display: grid;
    grid-template-columns: 1fr 280px;
