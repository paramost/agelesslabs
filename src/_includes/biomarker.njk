  /* Page-level animations */
  .bm-main > * { animation: fadeUp 0.5s ease both; }
  .bm-main > *:nth-child(2) { animation-delay: 0.05s; }
  .bm-main > *:nth-child(3) { animation-delay: 0.1s; }
  .bm-main > *:nth-child(4) { animation-delay: 0.15s; }
