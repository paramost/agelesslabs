<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">

<!-- Canonical & crawl directives -->
<link rel="canonical" href="https://agelesslabs.ai{{ page.url }}">
<meta name="robots" content="index, follow">

<!-- OpenGraph -->
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:site_name" content="AgelessLabs.ai">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="https://agelesslabs.ai{{ page.url }}">
<meta property="og:image" content="https://agelesslabs.ai/og-image.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@agelesslabsai">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="https://agelesslabs.ai/og-image.png">

<!-- Schema.org: Organization + WebSite -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://agelesslabs.ai/#organization",
      "name": "AgelessLabs.ai",
      "url": "https://agelesslabs.ai",
      "logo": {
        "@type": "ImageObject",
        "url": "https://agelesslabs.ai/favicon.svg"
      },
      "sameAs": [
        "https://twitter.com/agelesslabsai",
        "https://instagram.com/agelesslabsai"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://agelesslabs.ai/#website",
      "url": "https://agelesslabs.ai",
      "name": "AgelessLabs.ai",
      "description": "AI-powered longevity biomarker analysis. Understand what your lab results reveal about how long you'll live.",
      "publisher": {
        "@id": "https://agelesslabs.ai/#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://agelesslabs.ai/biomarkers/{search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
}
</script>

<link rel="stylesheet" href="/styles.css">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-28CHRFJLKJ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-28CHRFJLKJ');
</script>
<script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wa32lp8ja6");
</script>
</head>
<body>
<div class="container">

  <nav>
    <a href="/" class="logo">
      <span class="ageless">ageless</span><span class="labs">labs</span><span class="dot">.</span><span class="ai">ai</span>
    </a>
    <div class="nav-right">
      <a href="/#how-it-works" class="nav-link">How it works</a>
      <a href="/#lab-tests" class="nav-link">Lab Tests</a>
      {% if analyzePage %}
        <span class="badge">Beta — Free Interpreter</span>
      {% else %}
        <a href="/analyze" class="nav-cta">Try Free →</a>
      {% endif %}
    </div>
  </nav>

  {{ content | safe }}

  <footer>
    <a href="/" class="logo">
      <span class="ageless">ageless</span><span class="labs">labs</span><span class="dot">.</span><span class="ai">ai</span>
    </a>
    <div class="footer-links">
      <a href="/analyze">Analyze</a>
      <a href="/about">About</a>
      <a href="/privacy">Privacy</a>
      <a href="/disclaimer">Disclaimer</a>
      <a href="mailto:hello@agelesslabs.ai">Contact</a>
    </div>
    <div class="footer-disclaimer">For informational purposes only. Not medical advice. Always consult a qualified healthcare provider.</div>
  </footer>

</div>
</body>
</html>
