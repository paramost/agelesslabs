<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

<title>{{ title | safe }}</title>
<meta name="description" content="{{ description }}">

{% if noindex %}
<meta name="robots" content="noindex, follow">
{% else %}
<meta name="robots" content="index, follow">
{% endif %}

<!-- Canonical -->
<link rel="canonical" href="https://agelesslabs.ai{{ page.url }}">

<!-- OpenGraph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="AgelessLabs">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="https://agelesslabs.ai{{ page.url }}">
<meta property="og:image" content="https://agelesslabs.ai/og-image.png">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@agelesslabsai">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="https://agelesslabs.ai/og-image.png">

<!-- Organization + WebSite schema -->
<script type="application/ld+json">
{
"@context": "https://schema.org",
"@graph": [
{
"@type": "Organization",
"@id": "https://agelesslabs.ai/#organization",
"name": "AgelessLabs",
"url": "https://agelesslabs.ai",
"logo": {
"@type": "ImageObject",
"url": "https://agelesslabs.ai/og-image.png"
},
"sameAs": [
"https://twitter.com/agelesslabsai",
"https://www.instagram.com/agelesslabsai"
]
},
{
"@type": "WebSite",
"@id": "https://agelesslabs.ai/#website",
"url": "https://agelesslabs.ai",
"name": "AgelessLabs",
"description": "AI-powered longevity biomarker interpreter. Understand what your labs reveal about how long you'll live.",
"publisher": {
"@id": "https://agelesslabs.ai/#organization"
},
"potentialAction": {
"@type": "SearchAction",
"target": {
"@type": "EntryPoint",
"urlTemplate": "https://agelesslabs.ai/biomarkers/?q={search_term_string}"
},
"query-input": "required name=search_term_string"
}
}
]
}
</script>

<link rel="stylesheet" href="/styles.css">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">

<style>
/* --- Hamburger button --- */
.nav-hamburger {
display: none;
flex-direction: column;
justify-content: center;
align-items: center;
gap: 5px;
width: 40px;
height: 40px;
background: none;
border: 1px solid var(--border);
border-radius: 2px;
cursor: pointer;
padding: 0;
flex-shrink: 0;
}
.nav-hamburger span {
display: block;
width: 18px;
height: 1.5px;
background: var(--green);
border-radius: 1px;
}
@media (max-width: 1024px) {
.nav-hamburger { display: flex; }
}

/* --- Nav dropdown --- */
.nav-dropdown { position: relative; display: inline-flex; align-items: center; }
.nav-dropdown-toggle {
background: none; border: none; cursor: pointer; padding: 0;
font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
color: var(--text-dim);
}
.nav-dropdown-caret { font-size: 9px; margin-left: 3px; opacity: 0.5; transition: transform 0.2s; display: inline-block; }
.nav-dropdown-toggle[aria-expanded="true"] .nav-dropdown-caret { transform: rotate(180deg); opacity: 1; }
.nav-dropdown-menu {
display: none; position: absolute; top: calc(100% + 12px); left: 50%;
transform: translateX(-50%);
background: var(--bg2); border: 1px solid var(--border); border-radius: 3px;
min-width: 220px; padding: 6px 0; z-index: 200;
box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}
.nav-dropdown-menu::before {
content: ''; position: absolute; top: -5px; left: 50%; transform: translateX(-50%);
width: 8px; height: 8px; background: var(--bg2); border-left: 1px solid var(--border);
border-top: 1px solid var(--border); transform: translateX(-50%) rotate(45deg);
}
.nav-dropdown-menu.open { display: block; }
.nav-dropdown-menu a {
display: block; padding: 10px 18px;
font-family: 'Red Hat Display', sans-serif; font-size: 14px; font-weight: 500;
color: var(--text-dim); text-decoration: none; letter-spacing: -0.01em;
transition: color 0.15s, background 0.15s;
}
.nav-dropdown-menu a:hover { color: var(--white); background: rgba(181,201,160,0.05); }

/* --- Mobile menu overlay --- */
.mobile-menu {
position: fixed;
inset: 0;
z-index: 1000;
background: var(--bg);
transform: translateX(100%);
transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
overflow-y: auto;
-webkit-overflow-scrolling: touch;
}
.mobile-menu.open { transform: translateX(0); }
.mobile-menu-inner {
display: flex;
flex-direction: column;
min-height: 100%;
padding: 28px 28px 48px;
}
.mobile-menu-header {
display: flex;
align-items: center;
justify-content: space-between;
padding-bottom: 32px;
border-bottom: 1px solid var(--border);
margin-bottom: 40px;
}
.mobile-menu-close {
display: flex;
align-items: center;
justify-content: center;
width: 40px;
height: 40px;
background: none;
border: 1px solid var(--border);
border-radius: 2px;
cursor: pointer;
color: var(--text-dim);
transition: color 0.15s, border-color 0.15s;
flex-shrink: 0;
}
.mobile-menu-close:hover { color: var(--green); border-color: rgba(181,201,160,0.35); }
.mobile-menu-nav {
display: flex;
flex-direction: column;
margin-bottom: 40px;
}
.mobile-menu-nav a {
font-family: 'Red Hat Display', sans-serif;
font-size: 28px;
font-weight: 600;
color: var(--white);
text-decoration: none;
letter-spacing: -0.02em;
padding: 14px 0;
border-bottom: 1px solid var(--border);
display: flex;
align-items: center;
justify-content: space-between;
transition: color 0.15s;
line-height: 1;
}
.mobile-menu-nav a:hover { color: var(--green); }
.mobile-menu-nav a:last-child { border-bottom: none; }
.mobile-menu-nav-arrow {
font-size: 16px;
color: var(--green);
opacity: 0.4;
transition: opacity 0.15s, transform 0.15s;
}
.mobile-menu-nav a:hover .mobile-menu-nav-arrow { opacity: 1; transform: translateX(3px); }
.mobile-menu-email-slot {
background: var(--bg2);
border: 1px solid var(--border);
border-left: 3px solid var(--green);
border-radius: 0 3px 3px 0;
padding: 20px 24px;
margin-bottom: 40px;
}
.mobile-menu-email-eyebrow {
font-family: 'DM Mono', monospace;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(--green);
opacity: 0.8;
margin-bottom: 8px;
}
.mobile-menu-email-title {
font-size: 17px;
font-weight: 600;
color: var(--white);
letter-spacing: -0.01em;
margin-bottom: 6px;
}
.mobile-menu-email-desc {
font-size: 14px;
color: var(--text-dim);
line-height: 1.6;
margin: 0;
}
.mobile-menu-social {
margin-top: auto;
padding-top: 32px;
border-top: 1px solid var(--border);
display: flex;
align-items: center;
gap: 12px;
}
.mobile-menu-social-label {
font-family: 'DM Mono', monospace;
font-size: 10px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(--text-muted);
margin-right: 4px;
}
.mobile-menu-social a {
display: flex;
align-items: center;
justify-content: center;
width: 40px;
height: 40px;
border: 1px solid var(--border);
border-radius: 2px;
color: var(--text-dim);
text-decoration: none;
transition: color 0.15s, border-color 0.15s;
}
.mobile-menu-social a:hover { color: var(--green); border-color: rgba(181,201,160,0.35); }
.mobile-menu-social svg { width: 17px; height: 17px; fill: currentColor; }

/* --- Email form shared across all placements --- */
.email-form { margin-top: 16px; }
.email-form-row { display: flex; gap: 8px; }
.email-form input[type="email"] {
flex: 1;
min-width: 0;
background: var(--bg3);
border: 1px solid var(--border);
border-radius: 2px;
padding: 11px 14px;
font-family: 'Red Hat Display', sans-serif;
font-size: 15px;
color: var(--text);
outline: none;
transition: border-color 0.15s;
-webkit-appearance: none;
}
.email-form input[type="email"]::placeholder { color: var(--text-muted); }
.email-form input[type="email"]:focus { border-color: rgba(181,201,160,0.4); }
.email-form button[type="submit"] {
font-family: 'Red Hat Display', sans-serif;
font-size: 12px;
font-weight: 700;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(--bg);
background: var(--green);
border: none;
border-radius: 2px;
padding: 11px 18px;
cursor: pointer;
white-space: nowrap;
flex-shrink: 0;
transition: background 0.15s;
}
.email-form button[type="submit"]:hover { background: var(--green-bright); }
.email-form button[type="submit"]:disabled { opacity: 0.6; cursor: not-allowed; }
.email-form-success {
font-family: 'DM Mono', monospace;
font-size: 12px;
letter-spacing: 0.05em;
color: var(--green);
padding-top: 14px;
line-height: 1.5;
}
.email-form-error {
font-size: 13px;
color: #c87060;
margin-top: 8px;
display: none;
}
@media (max-width: 480px) {
.email-form-row { flex-direction: column; }
.email-form button[type="submit"] { width: 100%; padding: 13px; font-size: 13px; }
}

/* --- Feedback FAB --- */
.feedback-fab {
position: fixed;
bottom: calc(24px + env(safe-area-inset-bottom));
right: calc(24px + env(safe-area-inset-right));
width: 44px;
height: 44px;
background: var(--bg2);
border: 1px solid var(--border);
border-radius: 50%;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
z-index: 500;
transition: border-color 0.15s, background 0.15s;
box-shadow: 0 4px 16px rgba(0,0,0,0.4);
}
.feedback-fab:hover { border-color: rgba(181,201,160,0.4); background: var(--bg3); }
.feedback-fab { -webkit-touch-callout: none; -webkit-tap-highlight-color: transparent; user-select: none; touch-action: manipulation; }
.feedback-fab svg { width: 18px; height: 18px; fill: none; stroke: var(--text-dim); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: stroke 0.15s; }
.feedback-fab:hover svg { stroke: var(--green); }
.feedback-popover {
position: fixed;
bottom: calc(84px + env(safe-area-inset-bottom));
right: calc(24px + env(safe-area-inset-right));
width: 300px;
background: var(--bg2);
border: 1px solid var(--border);
border-radius: 4px;
padding: 18px;
z-index: 501;
box-shadow: 0 8px 32px rgba(0,0,0,0.5);
display: none;
}
.feedback-popover-close {
position: absolute;
top: 10px;
right: 10px;
width: 28px;
height: 28px;
display: flex;
align-items: center;
justify-content: center;
background: none;
border: none;
cursor: pointer;
color: var(--text-muted);
transition: color 0.15s;
padding: 0;
line-height: 1;
}
.feedback-popover-close:hover { color: var(--text-dim); }
.feedback-popover-close svg { width: 12px; height: 12px; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; }

.feedback-popover.open {
display: block;
border-color: var(--green);
box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px var(--green);
}
.feedback-popover.open .feedback-popover-label { color: var(--green); opacity: 1; }
.feedback-popover.open .feedback-popover-question { color: var(--white); }
.feedback-popover.open textarea { border-color: rgba(181,201,160,0.35); color: var(--white); }
.feedback-popover-label {
font-family: 'DM Mono', monospace;
font-size: 10px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(--text-muted);
margin-bottom: 8px;
}
.feedback-popover-question {
font-size: 13px;
font-weight: 500;
color: var(--text-dim);
margin-bottom: 10px;
letter-spacing: -0.01em;
line-height: 1.4;
}
.feedback-popover textarea {
width: 100%;
background: var(--bg3);
border: 1px solid var(--border);
border-radius: 2px;
padding: 10px 12px;
font-family: 'Red Hat Display', sans-serif;
font-size: 16px;
color: var(--text);
resize: none;
height: 80px;
outline: none;
transition: border-color 0.15s;
box-sizing: border-box;
-webkit-appearance: none;
}
.feedback-popover textarea::placeholder { color: var(--text-muted); }
.feedback-popover textarea:focus { border-color: rgba(181,201,160,0.35); }
.feedback-popover-footer {
display: flex;
align-items: center;
gap: 12px;
margin-top: 10px;
}
.feedback-popover-submit {
font-family: 'Red Hat Display', sans-serif;
font-size: 11px;
font-weight: 700;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(--bg);
background: var(--green);
border: none;
border-radius: 2px;
padding: 9px 16px;
cursor: pointer;
transition: background 0.15s;
flex-shrink: 0;
}
.feedback-popover-submit:hover { background: var(--green-bright); }
.feedback-popover-submit:disabled { opacity: 0.5; cursor: not-allowed; }
.feedback-popover-status {
font-family: 'DM Mono', monospace;
font-size: 11px;
letter-spacing: 0.04em;
color: var(--green);
display: none;
}
.feedback-popover-status.error { color: #c87060; }
@media (max-width: 480px) {
.feedback-fab { bottom: calc(16px + env(safe-area-inset-bottom)); right: calc(16px + env(safe-area-inset-right)); }
.feedback-popover { right: calc(16px + env(safe-area-inset-right)); bottom: calc(76px + env(safe-area-inset-bottom)); width: calc(100dvw - 32px); max-width: calc(100dvw - 32px); box-sizing: border-box; }
}
</style>

