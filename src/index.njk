    <div class="steps">
      <div class="step">
        <div class="step-title">Upload or paste your labs</div>
        <div class="step-desc">Upload a PDF or image of your blood test results, or paste the text directly. We support all major lab formats.</div>
      </div>
      <div class="step">
        <div class="step-title">AI analyzes every marker</div>
        <div class="step-desc">Our AI interprets each biomarker against longevity-optimized ranges — not just standard reference ranges designed to detect disease.</div>
      </div>
      <div class="step">
        <div class="step-title">Get your longevity score</div>
        <div class="step-desc">Receive a longevity score, plain-English explanations of every marker, and a prioritized action plan to extend your healthspan.</div>
      </div>
    </div>
    <div style="margin-top:36px;">
      <a href="/analyze" class="btn-outline">Analyze My Biomarkers →</a>
    </div>
  </section>

