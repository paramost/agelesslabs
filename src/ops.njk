          <span class="aff-note">Pending approval</span>
          <span class="aff-url">onetwenty.health</span>
          <button class="copy-btn-sm" onclick="copyAff(this, 'https://www.onetwenty.health')">Copy</button>
        </div>
        <div class="aff-row">
          <span class="aff-name">Marek Health</span>
          <span class="aff-note">Pending approval</span>
          <span class="aff-url">marekhealth.com</span>
          <button class="copy-btn-sm" onclick="copyAff(this, 'https://marekhealth.com')">Copy</button>
        </div>
      </div>
    </div>

    <!-- 4. Analytics -->
<div class="ops-section">
<p class="ops-section-title">Analytics — last 28 days</p>
<div class="analytics-grid">
<div class="analytics-card">
<div class="analytics-card-header">
<span class="analytics-card-title">Top pages — GSC clicks</span>
<span class="analytics-card-meta">Search Console</span>
</div>
<div id="gsc-container">
<div class="analytics-loading"><div class="spinner-sm"></div><span>Loading...</span></div>
</div>
</div>
<div class="analytics-card">
<div class="analytics-card-header">
<span class="analytics-card-title">Top pages — GA4 sessions</span>
<span class="analytics-card-meta">Google Analytics</span>
</div>
<div id="ga4-container">
<div class="analytics-loading"><div class="spinner-sm"></div><span>Loading...</span></div>
</div>
</div>
</div>
<div class="analytics-refresh">
<button onclick="loadAnalytics()">Refresh</button>
</div>
</div>

<!-- 4. Promotion Checklist -->
    <div class="ops-section">
      <p class="ops-section-title">Promotion checklist</p>
      <table class="checklist-table">
        <thead>
          <tr>
            <th>Page</th>
            <th>Twitter</th>
            <th>IG</th>
            <th>Reddit</th>
            <th>Threads</th>
          </tr>
        </thead>
        <tbody id="checklist-body"></tbody>
      </table>
      <div class="checklist-actions">
        <button class="cl-btn" onclick="resetChecklist()">Reset all</button>
      </div>
    </div>

  </div>
</div>

<script>
const PAGES = [
  { label: 'Homepage', url: '/' },
  { label: 'AI Tool', url: '/analyze/' },
  { label: 'Best Longevity Blood Panel', url: '/guides/best-longevity-blood-panel/' },
  { label: 'Blood Tests — Men Over 40', url: '/guides/blood-tests-men-over-40/' },
  { label: 'Blood Tests — Women Over 40', url: '/guides/blood-tests-women-over-40/' },
  { label: 'How to Lower ApoB', url: '/guides/how-to-lower-apob/' },
  { label: 'How to Improve Insulin Sensitivity', url: '/guides/how-to-improve-insulin-sensitivity/' },
  { label: 'How to Optimize Testosterone', url: '/guides/how-to-optimize-testosterone/' },
  { label: 'How to Reduce Inflammation', url: '/guides/how-to-reduce-inflammation/' },
  { label: 'How to Fix Nutrient Deficiencies', url: '/guides/how-to-fix-nutrient-deficiencies/' },
  { label: 'Ulta Lab Tests Review', url: '/reviews/ulta-lab-tests/' },
  { label: 'Superpower Review', url: '/reviews/superpower-health/' },
  { label: 'Function Health Review', url: '/reviews/function-health/' },
  { label: 'Longevity Test Comparison', url: '/compare/longevity-blood-tests/' },
  { label: 'Get Your Baseline', url: '/get-tested/' },
];

const PLATFORMS = ['twitter', 'instagram', 'reddit', 'threads'];
const CHAR_LIMITS = { twitter: 280, instagram: 2200, reddit: null, threads: 500 };
const CL_KEY = 'ops_checklist_v1';

let composedPosts = {};
let activePlatform = 'twitter';
let opsKey = '';

// -- Analytics
async function loadAnalytics() {
setAnalyticsLoading();
try {
const res = await fetch('/api/gsc-ga4?key=' + encodeURIComponent(opsKey));
if (!res.ok) {
const err = await res.json().catch(() => ({ error: 'Request failed' }));
throw new Error(err.error || 'Request failed');
}
const data = await res.json();
renderGSC(data.gsc || []);
renderGA4(data.ga4 || []);
} catch(err) {
document.getElementById('gsc-container').innerHTML = '<div class="analytics-error">Error: ' + err.message + '</div>';
document.getElementById('ga4-container').innerHTML = '<div class="analytics-error">Error: ' + err.message + '</div>';
}
}

function setAnalyticsLoading() {
const spinner = '<div class="analytics-loading"><div class="spinner-sm"></div><span>Loading...</span></div>';
document.getElementById('gsc-container').innerHTML = spinner;
document.getElementById('ga4-container').innerHTML = spinner;
}

function renderGSC(rows) {
if (!rows.length) {
document.getElementById('gsc-container').innerHTML = '<div class="analytics-loading">No data yet.</div>';
return;
}
const html = '<table class="analytics-table"><thead><tr><th>Page</th><th>Clicks</th><th>Impr.</th><th>CTR</th></tr></thead><tbody>' +
rows.map(r => '<tr><td><span class="analytics-page" title="' + r.page + '">' + r.page + '</span></td><td><span class="analytics-num">' + r.clicks + '</span></td><td>' + r.impressions + '</td><td>' + r.ctr + '</td></tr>').join('') +
'</tbody></table>';
document.getElementById('gsc-container').innerHTML = html;
}

function renderGA4(rows) {
if (!rows.length) {
document.getElementById('ga4-container').innerHTML = '<div class="analytics-loading">No data yet.</div>';
return;
}
const html = '<table class="analytics-table"><thead><tr><th>Page</th><th>Sessions</th><th>Views</th></tr></thead><tbody>' +
rows.map(r => '<tr><td><span class="analytics-page" title="' + r.page + '">' + r.page + '</span></td><td><span class="analytics-num">' + r.sessions + '</span></td><td>' + r.pageviews + '</td></tr>').join('') +
'</tbody></table>';
document.getElementById('ga4-container').innerHTML = html;
}

// ── Auth ──────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  document.getElementById('key-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') unlockOps();
  });
  document.getElementById('compose-url').addEventListener('keydown', e => {
    if (e.key === 'Enter') generatePosts();
  });
  buildChecklist();
});

async function unlockOps() {
  const key = document.getElementById('key-input').value.trim();
  if (!key) return;
  opsKey = key;
  try {
    const res = await fetch('/api/digest?key=' + encodeURIComponent(key), { method: 'HEAD' }).catch(() => fetch('/api/digest?key=' + encodeURIComponent(key)));
    if (res.status === 401) {
      document.getElementById('gate-error').style.display = 'block';
      return;
    }
    document.getElementById('gate-error').style.display = 'none';
    document.getElementById('gate-view').style.display = 'none';
    document.getElementById('dashboard-view').style.display = 'block';
  loadAnalytics();
  } catch(e) {
    document.getElementById('gate-error').style.display = 'none';
    document.getElementById('gate-view').style.display = 'none';
    document.getElementById('dashboard-view').style.display = 'block';
  loadAnalytics();
  }
}

// ── Quick Links ───────────────────────────────────
function openAllSocial() {
  const urls = [
    'https://x.com/agelesslabsai',
    'https://instagram.com/agelesslabs.ai',
    'https://www.threads.net/@agelesslabs.ai',
    'https://reddit.com/user/agelesslabs'
  ];
  urls.forEach(u => window.open(u, '_blank'));
}

// ── Post Composer ─────────────────────────────────
async function generatePosts() {
const urlInput = document.getElementById('compose-url');
const rawUrl = urlInput.value.trim();
if (!rawUrl) return;

const selected = ['twitter','instagram','reddit','threads'].filter(p =>
  document.getElementById('pcheck-' + p)?.checked
);
if (selected.length === 0) {
  alert('Select at least one platform.');
  return;
}

const btn = document.getElementById('compose-btn');
btn.disabled = true;
document.getElementById('compose-spinner').classList.add('visible');
document.getElementById('ptabs').style.display = 'none';
document.getElementById('post-output').classList.remove('visible');
document.getElementById('output-actions').style.display = 'none';
composedPosts = {};

try {
const fullUrl = rawUrl.startsWith('http') ? rawUrl : 'https://agelesslabs.ai' + rawUrl;

const platformGuides = {
  twitter: 'Twitter/X: Max 260 chars. Punchy hook, 1-2 data points or insights, end with the URL. No hashtags.',
  instagram: 'Instagram: 150-300 chars. Hook line, 2-3 value bullets (use ✦ as bullet), end with link in bio mention. 3-5 relevant hashtags at end.',
  reddit: 'Reddit: 3-5 sentences. Conversational, value-first, no self-promotion feel. Mention the site naturally. No hashtags.',
  threads: 'Threads: Max 480 chars. Warm, conversational tone similar to Twitter but slightly longer. Include the URL.'
};

const keys = selected.map(p => '"' + p + '": "..."').join(',\n  ');
const guides = selected.map(p => '- ' + platformGuides[p]).join('\n');

const prompt = 'You are a social media writer for AgelessLabs.ai — a longevity-focused health site that helps people understand their biomarkers and lab results through an AI tool.\n\nURL to promote: ' + fullUrl + '\n\nWrite posts for the following platforms only. Return ONLY valid JSON with this exact structure, no other text:\n{\n  ' + keys + '\n}\n\nGuidelines:\n' + guides + '\n- Voice: authoritative but not clinical. Speak to health-optimizers aged 35-65.\n- Always weave in the URL naturally.';

const res = await fetch('https://api.anthropic.com/v1/messages', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    model: 'claude-sonnet-4-20250514',
    max_tokens: 1000,
    messages: [{ role: 'user', content: prompt }]
  })
});

const data = await res.json();
const text = data.content?.[0]?.text || '';
const clean = text.replace(/```json|```/g, '').trim();
composedPosts = JSON.parse(clean);

// Build tabs only for selected platforms
const ptabs = document.getElementById('ptabs');
ptabs.innerHTML = selected.map((p, i) => {
  const label = { twitter: 'Twitter / X', instagram: 'Instagram', reddit: 'Reddit', threads: 'Threads' }[p];
  return '<button class="ptab' + (i === 0 ? ' active' : '') + '" onclick="showPlatform(\'' + p + '\')">' + label + '</button>';
}).join('');
ptabs.style.display = 'flex';
showPlatform(selected[0]);

} catch(err) {
document.getElementById('post-output').textContent = 'Error generating posts. Check the URL and try again.';
document.getElementById('post-output').classList.add('visible');
} finally {
btn.disabled = false;
document.getElementById('compose-spinner').classList.remove('visible');
}
}

function showPlatform(p) {
  activePlatform = p;
  document.querySelectorAll('.ptab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.ptab').forEach(t => {
    if (t.textContent.toLowerCase().includes(p === 'twitter' ? 'twitter' : p)) t.classList.add('active');
  });
  const text = composedPosts[p] || '';
  const output = document.getElementById('post-output');
  output.textContent = text;
  output.classList.add('visible');

  const actions = document.getElementById('output-actions');
  actions.style.display = 'flex';

  const limit = CHAR_LIMITS[p];
  const cc = document.getElementById('char-count');
  if (limit) {
    const over = text.length > limit;
    cc.textContent = text.length + ' / ' + limit;
    cc.className = 'char-count' + (over ? ' char-over' : '');
  } else {
    cc.textContent = text.length + ' chars';
    cc.className = 'char-count';
  }

  const btn = document.getElementById('copy-post-btn');
  btn.textContent = 'Copy';
  btn.classList.remove('copied');
}

function copyPost() {
  const text = document.getElementById('post-output').textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copy-post-btn');
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
  });
}

// ── Affiliate Links ───────────────────────────────
function copyAff(btn, url) {
  navigator.clipboard.writeText(url).then(() => {
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
  });
}

// ── Checklist ─────────────────────────────────────
function loadChecklist() {
  try { return JSON.parse(localStorage.getItem(CL_KEY) || '{}'); } catch { return {}; }
}

function saveChecklist(data) {
  localStorage.setItem(CL_KEY, JSON.stringify(data));
}

function buildChecklist() {
  const state = loadChecklist();
  const tbody = document.getElementById('checklist-body');
  tbody.innerHTML = PAGES.map(page => {
    const allDone = PLATFORMS.every(p => state[page.url + '_' + p]);
    return `<tr class="${allDone ? 'done-row' : ''}" id="row-${CSS.escape(page.url)}">
      <td><a class="page-link" href="${page.url}" target="_blank">${page.label}</a></td>
      ${PLATFORMS.map(p => {
        const key = page.url + '_' + p;
        const checked = state[key] ? 'checked' : '';
        return `<td class="check-cell"><input type="checkbox" ${checked} data-key="${key}" data-url="${page.url}" onchange="toggleCheck(this)" /></td>`;
      }).join('')}
    </tr>`;
  }).join('');
}

function toggleCheck(el) {
  const state = loadChecklist();
  state[el.dataset.key] = el.checked;
  saveChecklist(state);
  const row = el.closest('tr');
  const allChecks = row.querySelectorAll('input[type="checkbox"]');
  const allDone = Array.from(allChecks).every(c => c.checked);
  row.className = allDone ? 'done-row' : '';
}

function resetChecklist() {
  if (!confirm('Reset all promotion checkboxes?')) return;
  localStorage.removeItem(CL_KEY);
  buildChecklist();
}
</script>
