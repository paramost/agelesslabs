<style>
.ops-wrap {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 24px 80px;
}

/* Gate */
.ops-gate {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  padding: 80px 24px;
  text-align: center;
}
.ops-gate h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 1.6rem;
  color: var(--text-bright);
  margin: 0;
}
.ops-gate p { color: var(--text-muted); font-size: 0.95rem; margin: 0; }
.gate-row { display: flex; gap: 10px; width: 100%; max-width: 380px; }
.gate-row input {
  flex: 1;
  padding: 10px 14px;
  background: var(--surface-2, #1e201c);
  border: 1px solid var(--border, #2e3028);
  border-radius: 8px;
  color: var(--text-bright);
  font-size: 0.95rem;
  outline: none;
}
.gate-row input:focus { border-color: var(--green); }
.gate-row button {
  padding: 10px 20px;
  background: var(--green);
  color: #111210;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  font-size: 0.95rem;
}
.gate-row button:hover { opacity: 0.88; }
.gate-error { color: #e07070; font-size: 0.85rem; }

/* Dashboard */
.ops-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40px;
  flex-wrap: wrap;
  gap: 12px;
}
.ops-header h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 1.5rem;
  color: var(--text-bright);
  margin: 0;
}
.ops-badge {
  font-size: 0.72rem;
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: #1e2a1a;
  color: var(--green);
  border: 1px solid #2d3d28;
  padding: 3px 10px;
  border-radius: 4px;
}

/* Section */
.ops-section {
  margin-bottom: 48px;
}
.ops-section-title {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0 0 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border, #2e3028);
}

/* Quick links */
.quick-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.ql-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 16px;
  border-radius: 8px;
  font-size: 0.88rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: opacity 0.15s;
}
.ql-btn:hover { opacity: 0.82; }
.ql-btn-primary { background: var(--green); color: #111210; }
.ql-btn-outline {
  background: transparent;
  border: 1px solid var(--border, #2e3028);
  color: var(--text-dim, #a0a89a);
}
.ql-btn-outline:hover { border-color: var(--green); color: var(--green); }
.ql-icon { width: 16px; height: 16px; flex-shrink: 0; }

/* Composer */
.composer-row {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}
.composer-row input {
  flex: 1;
  padding: 10px 14px;
  background: var(--surface-2, #1e201c);
  border: 1px solid var(--border, #2e3028);
  border-radius: 8px;
  color: var(--text-bright);
  font-size: 0.9rem;
  outline: none;
}
.composer-row input:focus { border-color: var(--green); }
.composer-row input::placeholder { color: var(--text-muted); }
.composer-row button {
  padding: 10px 20px;
  background: var(--green);
  color: #111210;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  font-size: 0.88rem;
  white-space: nowrap;
}
.composer-row button:hover { opacity: 0.88; }
.composer-row button:disabled { opacity: 0.5; cursor: not-allowed; }

/* Platform checkboxes */
.platform-checks {
  display: flex;
  gap: 18px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}
.pcheck-label {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 0.85rem;
  font-family: 'DM Mono', monospace;
  color: var(--text-dim, #a0a89a);
  cursor: pointer;
  user-select: none;
}
.pcheck-label input[type="checkbox"] {
  width: 15px; height: 15px;
  accent-color: var(--green);
  cursor: pointer;
}

.platform-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.ptab {
  padding: 5px 14px;
  border-radius: 6px;
  font-size: 0.8rem;
  font-family: 'DM Mono', monospace;
  cursor: pointer;
  border: 1px solid var(--border, #2e3028);
  background: transparent;
  color: var(--text-dim, #a0a89a);
  transition: border-color 0.15s, color 0.15s;
}
.ptab.active, .ptab:hover { border-color: var(--green); color: var(--green); }

.post-output {
  background: #111210;
  border: 1px solid var(--border, #2e3028);
  border-radius: 8px;
  padding: 16px;
  font-size: 0.87rem;
  color: var(--text-dim, #a0a89a);
  line-height: 1.6;
  white-space: pre-wrap;
  min-height: 80px;
  display: none;
}
.post-output.visible { display: block; }

.output-actions {
  display: flex;
  gap: 8px;
  margin-top: 10px;
  align-items: center;
  flex-wrap: wrap;
}
.copy-btn {
  padding: 6px 14px;
  border-radius: 6px;
  background: var(--green);
  color: #111210;
  font-weight: 600;
  font-size: 0.8rem;
  border: none;
  cursor: pointer;
}
.copy-btn:hover { opacity: 0.85; }
.copy-btn.copied { background: #5a8050; color: #eef2ea; }
.char-count {
  font-size: 0.78rem;
  font-family: 'DM Mono', monospace;
  color: var(--text-muted);
  margin-left: auto;
}
.char-over { color: #e07070; }

.composer-spinner {
  display: none;
  align-items: center;
  gap: 10px;
  color: var(--text-muted);
  font-size: 0.88rem;
  padding: 8px 0;
}
.composer-spinner.visible { display: flex; }
.spinner-sm {
  width: 16px; height: 16px;
  border: 2px solid var(--border, #2e3028);
  border-top-color: var(--green);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Affiliate links */
.aff-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.aff-row {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface-1, #171916);
  border: 1px solid var(--border, #2e3028);
  border-radius: 8px;
  padding: 12px 16px;
}
.aff-name {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-bright);
  min-width: 130px;
}
.aff-note {
  font-size: 0.78rem;
  color: var(--text-muted);
  font-family: 'DM Mono', monospace;
  flex: 1;
}
.aff-url {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-family: 'DM Mono', monospace;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.copy-btn-sm {
  padding: 5px 12px;
  border-radius: 6px;
  background: transparent;
  border: 1px solid var(--border, #2e3028);
  color: var(--text-dim, #a0a89a);
  font-size: 0.78rem;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
}
.copy-btn-sm:hover { border-color: var(--green); color: var(--green); }
.copy-btn-sm.copied { border-color: #5a8050; color: #5a8050; }

/* Analytics */
.analytics-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px;
}
@media (max-width: 640px) {
.analytics-grid { grid-template-columns: 1fr; }
}
.analytics-card {
background: var(--surface-1, #171916);
border: 1px solid var(--border, #2e3028);
border-radius: 10px;
overflow: hidden;
}
.analytics-card-header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 14px 16px 10px;
border-bottom: 1px solid var(--border, #2e3028);
}
.analytics-card-title {
font-family: 'DM Mono', monospace;
font-size: 0.72rem;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(--text-muted);
}
.analytics-card-meta {
font-family: 'DM Mono', monospace;
font-size: 0.68rem;
color: var(--text-muted);
opacity: 0.6;
}
.analytics-table {
width: 100%;
border-collapse: collapse;
font-size: 0.82rem;
}
.analytics-table th {
font-family: 'DM Mono', monospace;
font-size: 0.68rem;
letter-spacing: 0.05em;
text-transform: uppercase;
color: var(--text-muted);
font-weight: 400;
padding: 8px 16px;
text-align: left;
border-bottom: 1px solid var(--border, #2e3028);
}
.analytics-table th:not(:first-child) { text-align: right; }
.analytics-table td {
padding: 8px 16px;
border-bottom: 1px solid #1a1c17;
color: var(--text-dim, #a0a89a);
vertical-align: middle;
font-size: 0.82rem;
}
.analytics-table td:not(:first-child) { text-align: right; font-family: 'DM Mono', monospace; }
.analytics-table tr:last-child td { border-bottom: none; }
.analytics-table tr:hover td { background: #14160f; }
.analytics-page {
color: var(--text-dim, #a0a89a);
font-family: 'DM Mono', monospace;
font-size: 0.76rem;
max-width: 200px;
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
display: block;
}
.analytics-num {
color: var(--text-bright);
font-weight: 600;
}
.analytics-loading {
padding: 24px 16px;
text-align: center;
color: var(--text-muted);
font-size: 0.85rem;
display: flex;
align-items: center;
justify-content: center;
gap: 10px;
}
.analytics-error {
padding: 16px;
color: #e07070;
font-size: 0.82rem;
font-family: 'DM Mono', monospace;
}
.analytics-refresh {
display: flex;
justify-content: flex-end;
margin-top: 10px;
}
.analytics-refresh button {
padding: 5px 14px;
border-radius: 6px;
font-size: 0.78rem;
font-family: 'DM Mono', monospace;
cursor: pointer;
border: 1px solid var(--border, #2e3028);
background: transparent;
color: var(--text-dim, #a0a89a);
}
.analytics-refresh button:hover { border-color: var(--green); color: var(--green); }

/* Checklist */
.checklist-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}
.checklist-table th {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  font-weight: 400;
  padding: 8px 10px;
  text-align: left;
  border-bottom: 1px solid var(--border, #2e3028);
}
.checklist-table th:not(:first-child) { text-align: center; }
.checklist-table td {
  padding: 10px 10px;
  border-bottom: 1px solid #1e2018;
  color: var(--text-dim, #a0a89a);
  vertical-align: middle;
}
.checklist-table td:not(:first-child) { text-align: center; }
.checklist-table tr:last-child td { border-bottom: none; }
.checklist-table tr:hover td { background: #14160f; }
.page-link {
  color: var(--text-dim, #a0a89a);
  text-decoration: none;
  font-size: 0.85rem;
}
.page-link:hover { color: var(--green); }
.check-cell input[type="checkbox"] {
  width: 16px; height: 16px;
  accent-color: var(--green);
  cursor: pointer;
}
.done-row td { opacity: 0.45; }
.done-row td:first-child .page-link { text-decoration: line-through; }

.checklist-actions {
  display: flex;
  gap: 10px;
  margin-top: 14px;
}
.cl-btn {
  padding: 5px 14px;
  border-radius: 6px;
  font-size: 0.78rem;
  font-family: 'DM Mono', monospace;
  cursor: pointer;
  border: 1px solid var(--border, #2e3028);
  background: transparent;
  color: var(--text-dim, #a0a89a);
}
.cl-btn:hover { border-color: var(--green); color: var(--green); }
</style>

