---
layout: base.njk
title: "Search | AgelessLabs"
permalink: /search/index.html
description: "Search the AgelessLabs biomarker library, guides, and reviews."
---

<style>
/* ── Search page ──────────────────────────────────────────────────────── */
.search-hero {
  padding: 40px 0 32px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 40px;
}
.search-eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.25em;
  color: var(--green);
  text-transform: uppercase;
  margin-bottom: 16px;
  opacity: 0.7;
  display: flex;
  align-items: center;
  gap: 10px;
}
.search-eyebrow::before {
  content: '';
  width: 24px;
  height: 1px;
  background: var(--green);
  opacity: 0.5;
}
.search-hero h1 {
  font-size: clamp(28px, 3vw, 40px);
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.02em;
  margin-bottom: 0;
}

/* Pagefind UI overrides — match AgelessLabs design system */
.pagefind-ui {
  --pagefind-ui-scale: 1;
  --pagefind-ui-primary: #b5c9a0;
  --pagefind-ui-text: #d4dece;
  --pagefind-ui-background: #191a17;
  --pagefind-ui-border: rgba(181,201,160,0.15);
  --pagefind-ui-tag: #1e1f1c;
  --pagefind-ui-border-width: 1px;
  --pagefind-ui-border-radius: 2px;
  --pagefind-ui-image-border-radius: 2px;
  --pagefind-ui-image-box-ratio: 3/2;
  --pagefind-ui-font: 'Red Hat Display', sans-serif;
}

/* Override Pagefind's search input */
.pagefind-ui__search-input {
  background: var(--bg2) !important;
  border: 1px solid var(--border) !important;
  border-radius: 2px !important;
  color: var(--text) !important;
  font-family: 'Red Hat Display', sans-serif !important;
  font-size: 16px !important;
  padding: 14px 18px 14px 44px !important;
  outline: none !important;
  transition: border-color 0.15s !important;
  width: 100% !important;
  box-sizing: border-box !important;
}
.pagefind-ui__search-input:focus {
  border-color: rgba(181,201,160,0.4) !important;
}
.pagefind-ui__search-input::placeholder {
  color: var(--text-muted) !important;
}

/* Search button */
.pagefind-ui__search-clear {
  width: 28px !important;
  height: 28px !important;
  border-radius: 50% !important;
  background: var(--bg3) !important;
  border: 1px solid var(--border) !important;
  color: transparent !important;
  font-size: 0 !important;
  position: relative !important;
  flex-shrink: 0 !important;
  margin-right: 8px !important;
  cursor: pointer !important;
}
.pagefind-ui__search-clear::before,
.pagefind-ui__search-clear::after {
  content: '' !important;
  position: absolute !important;
  top: 50% !important;
  left: 50% !important;
  width: 10px !important;
  height: 1.5px !important;
  background: var(--text-dim) !important;
  border-radius: 1px !important;
}
.pagefind-ui__search-clear::before { transform: translate(-50%, -50%) rotate(45deg) !important; }
.pagefind-ui__search-clear::after { transform: translate(-50%, -50%) rotate(-45deg) !important; }
.pagefind-ui__search-clear:hover { border-color: rgba(181,201,160,0.35) !important; background: var(--bg2) !important; }
.pagefind-ui__search-clear:hover::before,
.pagefind-ui__search-clear:hover::after { background: var(--green) !important; }

/* Results */
.pagefind-ui__results-area {
  margin-top: 32px !important;
}
.pagefind-ui__message {
  font-family: 'DM Mono', monospace !important;
  font-size: 10px !important;
  letter-spacing: 0.1em !important;
  text-transform: uppercase !important;
  color: var(--text-muted) !important;
  margin-bottom: 24px !important;
}
.pagefind-ui__result {
  background: var(--bg2) !important;
  border: 1px solid var(--border) !important;
  border-radius: 3px !important;
  padding: 20px 24px !important;
  margin-bottom: 3px !important;
  transition: border-color 0.15s !important;
  list-style: none !important;
}
.pagefind-ui__result:hover {
  border-color: rgba(181,201,160,0.3) !important;
}
.pagefind-ui__result-link {
  font-family: 'Red Hat Display', sans-serif !important;
  font-size: 17px !important;
  font-weight: 600 !important;
  color: var(--white) !important;
  text-decoration: none !important;
  letter-spacing: -0.01em !important;
  display: block !important;
  margin-bottom: 6px !important;
}
.pagefind-ui__result-link:hover {
  color: var(--green) !important;
}
.pagefind-ui__result-excerpt {
  font-size: 14px !important;
  color: var(--text-dim) !important;
  line-height: 1.7 !important;
  font-weight: 400 !important;
  margin: 0 !important;
}
.pagefind-ui__result-excerpt mark {
  background: rgba(181,201,160,0.15) !important;
  color: var(--green) !important;
  border-radius: 2px !important;
  padding: 0 2px !important;
}

/* Category badge on each result */
.pagefind-ui__result-tags {
  display: flex !important;
  gap: 6px !important;
  margin-bottom: 8px !important;
  flex-wrap: wrap !important;
}
.pagefind-ui__result-tag {
  font-family: 'DM Mono', monospace !important;
  font-size: 8px !important;
  letter-spacing: 0.15em !important;
  text-transform: uppercase !important;
  color: var(--gold) !important;
  background: rgba(200,169,110,0.08) !important;
  border: 1px solid rgba(200,169,110,0.15) !important;
  padding: 2px 8px !important;
  border-radius: 2px !important;
}

/* Load more button */
.pagefind-ui__button {
  font-family: 'Red Hat Display', sans-serif !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  letter-spacing: 0.08em !important;
  text-transform: uppercase !important;
  color: var(--green) !important;
  background: transparent !important;
  border: 1px solid var(--green) !important;
  border-radius: 2px !important;
  padding: 10px 24px !important;
  cursor: pointer !important;
  margin-top: 24px !important;
  transition: all 0.15s !important;
}
.pagefind-ui__button:hover {
  background: var(--green) !important;
  color: var(--bg) !important;
}

/* No results state */
.pagefind-ui__result-inner {
  display: flex !important;
  flex-direction: column !important;
}

@media (max-width: 600px) {
  .search-hero { padding: 28px 0 24px; }
}
</style>

<div class="search-hero">
  <div class="search-eyebrow">Search</div>
  <h1>Find what you're looking for.</h1>
</div>

<div id="search" data-pagefind-ignore></div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js"></script>
<script>
(function() {
  // Initialise Pagefind UI
  var pf = new PagefindUI({
    element: '#search',
    showImages: false,
    showEmptyFilters: false,
    resetStyles: false,
    excerptLength: 24,
    highlightParam: 'highlight'
  });

  // Read ?q= param and pre-populate + auto-search
  var params = new URLSearchParams(window.location.search);
  var q = params.get('q');
  if (q) {
    pf.triggerSearch(q);
  }

  // Replace Pagefind's "Clear" text with an ✕ SVG icon
  var clearObserver = new MutationObserver(function() {
    var clearBtn = document.querySelector('.pagefind-ui__search-clear');
    if (clearBtn && clearBtn.textContent.trim() === 'Clear') {
      clearBtn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><line x1="1" y1="1" x2="9" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
    }
  });
  clearObserver.observe(document.getElementById('search'), { childList: true, subtree: true });

    // Auto-focus the search input on page load (desktop + mobile)
  // Pagefind renders the input asynchronously so we poll briefly
  var attempts = 0;
  var focusInterval = setInterval(function() {
    var input = document.querySelector('.pagefind-ui__search-input');
    if (input) {
      input.focus();
      // If there's a pre-populated query, move cursor to end
      if (q) {
        var len = input.value.length;
        input.setSelectionRange(len, len);
      }
      clearInterval(focusInterval);
    }
    if (++attempts > 20) clearInterval(focusInterval); // give up after ~1s
  }, 50);
})();
</script>
