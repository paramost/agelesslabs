    ? [
        { type: 'image', source: { type: 'base64', media_type: labData.mimeType, data: labData.base64 } },
        { type: 'text',  text: 'Please analyze the lab results in this image.' },
      ]
    : [{ type: 'text', text: `Analyze these lab results:\n\n${labData.text}` }];

  try {
    const response = await fetch('/api/analyze', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model:      'claude-sonnet-4-6',
        max_tokens: 4000,
        system:     PAID_PROMPT,
        messages:   [{ role: 'user', content: messageContent }],
      }),
    });
    const data  = await response.json();
    clearInterval(msgInterval);
    const raw   = data.content.map(i => i.text || '').join('');
    const clean = raw.replace(/```json|```/g, '').trim();
    renderPaidReport(JSON.parse(clean));
  } catch (err) {
    clearInterval(msgInterval);
    verifyText.textContent = 'Error generating report. Please contact support.';
    return;
  }

  verifyState.classList.remove('active');
  document.getElementById('paidReport').classList.add('active');
  document.getElementById('paidReport').scrollIntoView({ behavior: 'smooth', block: 'start' });
  sessionStorage.removeItem('al_lab_data');
}

// ── Paid report rendering ────────────────────────────────────────────────────
function renderPaidReport(data) {
  document.getElementById('paidScoreValue').textContent = data.score;
  document.getElementById('paidNarrative').textContent  = data.narrative;

  // Biomarkers
  document.getElementById('paidBiomarkerGrid').innerHTML = data.biomarkers.map(b => `
    <div class="paid-biomarker-row">
      <div class="paid-bm-top">
        <div>
          <div class="paid-bm-name">${b.name}</div>
        </div>
        <div class="biomarker-value">${b.value}</div>
        <div class="status-pill status-${b.status}">${b.status}</div>
      </div>
      <div class="paid-bm-desc">${b.description}</div>
      ${b.mechanism ? `<div class="paid-bm-mechanism">${b.mechanism}</div>` : ''}
      <div class="paid-ranges">
        ${b.longevity_range ? `<div class="paid-range-item">Longevity optimal: <span>${b.longevity_range}</span></div>` : ''}
        ${b.standard_range  ? `<div class="paid-range-item">Standard range: <span>${b.standard_range}</span></div>`   : ''}
      </div>
    </div>`).join('');

  // Marker interactions
  const interactions = data.marker_interactions || [];
  if (interactions.length) {
    document.getElementById('paidInteractionsList').innerHTML = interactions.map(i => `
      <div class="interaction-card severity-${i.severity}">
        <div class="interaction-title">${i.title}</div>
        <div class="interaction-markers">${i.markers.map(m => `<span class="interaction-marker-tag">${m}</span>`).join('')}</div>
        <div class="interaction-insight">${i.insight}</div>
      </div>`).join('');
  } else {
    document.getElementById('paidInteractionsSection').style.display = 'none';
  }

  // Action plan
  document.getElementById('paidActionPlan').innerHTML = (data.action_plan || []).map(a => `
    <div class="action-item">
      <div class="action-rank">${a.rank}</div>
      <div class="action-body">
        <div class="action-title">${a.title}</div>
        <div class="action-meta">
          <span class="action-impact ${a.impact}">${a.impact} impact</span>
          <span class="action-timeline">${a.timeline}</span>
        </div>
        <div class="action-detail">${a.detail}</div>
      </div>
    </div>`).join('');

  // Missing tests + affiliate links
  const missing = data.missing_tests || [];
  if (missing.length) {
    document.getElementById('paidMissingTests').innerHTML = missing.map(t => {
      const aff   = AFFILIATE[t.name] || {};
      const links = [
        aff.ulta        ? `<a href="${aff.ulta}"        class="affiliate-link ulta"       target="_blank" rel="noopener noreferrer">Order — Ulta Lab Tests →</a>`  : '',
        aff.function    ? `<a href="${aff.function}"    class="affiliate-link function"   target="_blank" rel="noopener noreferrer">Order — Function Health →</a>` : '',
        aff.omegaquant  ? `<a href="${aff.omegaquant}"  class="affiliate-link omegaquant" target="_blank" rel="noopener noreferrer">Order — OmegaQuant →</a>`      : '',
      ].filter(Boolean).join('');
      return `
        <div class="missing-test-item">
          <div class="missing-test-left">
            <div class="missing-test-priority ${t.priority}">${t.priority} priority</div>
            <div class="missing-test-name">${t.name}</div>
            <div class="missing-test-reason">${t.reason}</div>
          </div>
          ${links ? `<div class="missing-test-links">${links}</div>` : ''}
        </div>`;
    }).join('');
  } else {
    document.getElementById('paidMissingSection').style.display = 'none';
  }

  // Hide panel CTA if no significant missing tests
  const highPriority = missing.filter(t => t.priority === 'high');
  if (highPriority.length < 2) {
    document.getElementById('paidPanelCta').style.display = 'none';
  }
}

