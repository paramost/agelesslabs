const loadingMessages = ["Interpreting biomarkers...","Analyzing longevity markers...","Calculating your score...","Generating recommendations..."];

async function analyzeLabResults() {
  const btn        = document.getElementById('analyzeBtn');
  const loading    = document.getElementById('loadingState');
  const results    = document.getElementById('resultsSection');
  const pastedText = document.getElementById('labInput').value.trim();
  const hasImage   = uploadedImageBase64 !== null;

  if (!hasImage && !pastedText) {
    if (activeTab === 'upload') {
      document.getElementById('uploadStatus').textContent = 'Please upload a file first.';
      document.getElementById('uploadStatus').classList.add('active');
    } else {
      document.getElementById('labInput').focus();
    }
    return;
  }

  // Save lab data for potential paid upgrade
  const labData = hasImage
    ? { type: 'image', base64: uploadedImageBase64, mimeType: uploadedImageType }
    : { type: 'text', text: pastedText };
  sessionStorage.setItem('al_lab_data', JSON.stringify(labData));

  btn.disabled = true;
  loading.classList.add('active');
  results.classList.remove('active');
  document.getElementById('analyzeError').style.display = 'none';

  let msgIdx = 0;
  const msgInterval = setInterval(() => {
    msgIdx = (msgIdx + 1) % loadingMessages.length;
    document.getElementById('loadingText').textContent = loadingMessages[msgIdx];
  }, 1200);

  const messageContent = buildMessageContent(hasImage, pastedText);

  try {
    const response = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 2000,
        system: FREE_PROMPT,
        messages: [{ role: 'user', content: messageContent }],
      }),
    });
    const data = await response.json();
    clearInterval(msgInterval);
    const raw   = data.content.map(i => i.text || '').join('');
    const clean = raw.replace(/```json|```/g, '').trim();
    renderFreeResults(JSON.parse(clean));
  } catch (err) {
    clearInterval(msgInterval);
    loading.classList.remove('active');
    btn.disabled = false;
    document.getElementById('loadingText').textContent = 'Interpreting biomarkers...';
    const errorDiv = document.getElementById('analyzeError');
    errorDiv.style.display = 'block';
    errorDiv.textContent   = 'Something went wrong. Please check your connection and try again.';
    return;
  }

  loading.classList.remove('active');
  btn.disabled = false;
  results.classList.add('active');
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function buildMessageContent(hasImage, pastedText) {
  if (hasImage) {
    return [
      { type: 'image', source: { type: 'base64', media_type: uploadedImageType, data: uploadedImageBase64 } },
      { type: 'text',  text: 'Please analyze the lab results in this image.' },
    ];
  }
  return [{ type: 'text', text: `Analyze these lab results:\n\n${pastedText}` }];
}

function renderFreeResults(data) {
  document.getElementById('scoreValue').textContent   = data.score;
  document.getElementById('narrativeText').textContent = data.narrative;
  document.getElementById('biomarkerGrid').innerHTML  = data.biomarkers.map(b => `
    <div class="biomarker-row">
      <div>
        <div class="biomarker-name">${b.name}</div>
        <div class="biomarker-desc">${b.description}</div>
      </div>
      <div class="biomarker-value">${b.value}</div>
      <div class="status-pill status-${b.status}">${b.status}</div>
    </div>`).join('');
  document.getElementById('recommendationsList').innerHTML = data.recommendations.map((r, i) => `
    <div class="rec-item">
      <div class="rec-number">0${i + 1}</div>
      <div class="rec-text"><strong>${r.title}</strong> — ${r.detail}</div>
    </div>`).join('');
}

