// ── File processing ──────────────────────────────────────────────────────────
async function processFile(file) {
  const status = document.getElementById('uploadStatus');
  status.classList.add('active');
  uploadedImageBase64 = null; uploadedImageType = null;
  const ext = file.name.split('.').pop().toLowerCase();
  if (ext === 'pdf') {
    status.textContent = 'Reading PDF...';
    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      let text = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        text += content.items.map(item => item.str).join(' ') + '\n';
      }
      if (text.trim().length > 20) {
        document.getElementById('labInput').value = text.trim();
        status.textContent = `✓ PDF extracted — ${pdf.numPages} page${pdf.numPages > 1 ? 's' : ''} · ready to analyze`;
      } else {
        await pdfPageToImage(file, status);
      }
    } catch (err) {
      status.textContent = 'Could not read PDF. Try a JPG or PNG screenshot instead.';
    }
  } else if (['jpg','jpeg','png','webp'].includes(ext)) {
    status.textContent = 'Loading image...';
    try {
      uploadedImageBase64 = await fileToBase64(file);
      uploadedImageType   = file.type;
      status.textContent  = `✓ ${file.name} ready to analyze`;
    } catch (err) {
      status.textContent = 'Could not load image. Please try again.';
    }
  } else {
    status.textContent = 'Unsupported file type. Please upload a PDF, JPG, or PNG.';
  }
}

async function pdfPageToImage(file, status) {
  status.textContent = 'Converting PDF to image...';
  const arrayBuffer = await file.arrayBuffer();
  const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
  const page = await pdf.getPage(1);
  const viewport = page.getViewport({ scale: 2 });
  const canvas = document.createElement('canvas');
  canvas.width = viewport.width; canvas.height = viewport.height;
  await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
  uploadedImageBase64 = canvas.toDataURL('image/jpeg', 0.9).split(',')[1];
  uploadedImageType   = 'image/jpeg';
  status.textContent  = '✓ PDF converted to image · ready to analyze';
}

function fileToBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload  = () => resolve(reader.result.split(',')[1]);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

