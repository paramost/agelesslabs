  <footer>
    <a href="/" class="logo">
      <span class="ageless">ageless</span><span class="labs">labs</span><span class="dot">.</span><span class="ai">ai</span>
    </a>
    <div class="footer-links">
      <a href="/about">About</a>
      <a href="/privacy">Privacy</a>
      <a href="/disclaimer">Disclaimer</a>
    </div>
  </footer>
{% endblock %}

{% block scripts %}
<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

let uploadedImageBase64 = null;
let uploadedImageType = null;
let activeTab = 'upload';

function switchTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.tab-btn').forEach((b, i) => {
    b.classList.toggle('active', (i === 0 && tab === 'upload') || (i === 1 && tab === 'paste'));
  });
  document.getElementById('tab-upload').classList.toggle('active', tab === 'upload');
  document.getElementById('tab-paste').classList.toggle('active', tab === 'paste');
  if (tab === 'paste') { uploadedImageBase64 = null; uploadedImageType = null; }
}

const zone = document.getElementById('uploadZone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
zone.addEventListener('drop', e => {
  e.preventDefault();
  zone.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file) processFile(file);
});

function handleFileSelect(e) {
  const file = e.target.files[0];
  if (file) processFile(file);
}

async function processFile(file) {
  const status = document.getElementById('uploadStatus');
  status.classList.add('active');
  uploadedImageBase64 = null;
  uploadedImageType = null;
  const ext = file.name.split('.').pop().toLowerCase();

  if (ext === 'pdf') {
    status.textContent = 'Reading PDF...';
    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      let text = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        text += content.items.map(item => item.str).join(' ') + '\n';
      }
      if (text.trim().length > 20) {
        document.getElementById('labInput').value = text.trim();
        switchTab('paste');
        status.textContent = `✓ PDF extracted — ${pdf.numPages} page${pdf.numPages > 1 ? 's' : ''} · ready to analyze`;
        status.classList.add('active');
      } else {
        await pdfPageToImage(file, status);
      }
    } catch (err) {
      status.textContent = 'Could not read PDF. Try a JPG or PNG screenshot instead.';
    }
  } else if (['jpg','jpeg','png','webp'].includes(ext)) {
    status.textContent = 'Loading image...';
    try {
      const base64 = await fileToBase64(file);
      uploadedImageBase64 = base64;
      uploadedImageType = file.type;
      status.textContent = `✓ ${file.name} ready to analyze`;
    } catch (err) {
      status.textContent = 'Could not load image. Please try again.';
    }
  } else {
    status.textContent = 'Unsupported file type. Please upload a PDF, JPG, or PNG.';
  }
}

async function pdfPageToImage(file, status) {
  status.textContent = 'Converting PDF to image...';
  const arrayBuffer = await file.arrayBuffer();
  const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
  const page = await pdf.getPage(1);
  const viewport = page.getViewport({ scale: 2 });
  const canvas = document.createElement('canvas');
  canvas.width = viewport.width;
  canvas.height = viewport.height;
  await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
  uploadedImageBase64 = canvas.toDataURL('image/jpeg', 0.9).split(',')[1];
  uploadedImageType = 'image/jpeg';
  status.textContent = '✓ PDF converted to image · ready to analyze';
}

function fileToBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result.split(',')[1]);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

const examples = {
  metabolic: `Glucose: 94 mg/dL\nHbA1c: 5.2%\nInsulin (fasting): 6.2 uIU/mL\nALT: 22 U/L\nAST: 19 U/L\nCreatinine: 0.9 mg/dL\neGFR: 92 mL/min`,
  lipid: `Total Cholesterol: 212 mg/dL\nLDL: 138 mg/dL\nHDL: 52 mg/dL\nTriglycerides: 142 mg/dL\nApoB: 98 mg/dL\nhsCRP: 1.4 mg/L`,
  longevity: `Glucose: 88 mg/dL\nHbA1c: 5.1%\nTotal Cholesterol: 195 mg/dL\nLDL: 118 mg/dL\nHDL: 64 mg/dL\nApoB: 82 mg/dL\nTriglycerides: 76 mg/dL\nhsCRP: 0.4 mg/L\nHomocysteine: 7.2 umol/L\nVitamin D: 52 ng/mL\nIGF-1: 148 ng/mL\nTSH: 1.6 mIU/L\nTestosterone: 620 ng/dL\nFerritin: 68 ng/mL`
};

function loadExample(type) {
  document.getElementById('labInput').value = examples[type];
}

const loadingMessages = [
  "Interpreting biomarkers...",
  "Analyzing longevity markers...",
  "Calculating your score...",
  "Generating recommendations..."
];

async function analyzeLabResults() {
  const btn = document.getElementById('analyzeBtn');
  const loading = document.getElementById('loadingState');
  const results = document.getElementById('resultsSection');
  const pastedText = document.getElementById('labInput').value.trim();
  const hasImage = uploadedImageBase64 !== null;

  if (!hasImage && !pastedText) {
    if (activeTab === 'upload') {
      document.getElementById('uploadStatus').textContent = 'Please upload a file first.';
      document.getElementById('uploadStatus').classList.add('active');
    } else {
      document.getElementById('labInput').focus();
    }
    return;
  }

  btn.disabled = true;
  loading.classList.add('active');
  results.classList.remove('active');

  let msgIdx = 0;
  const msgInterval = setInterval(() => {
    msgIdx = (msgIdx + 1) % loadingMessages.length;
    document.getElementById('loadingText').textContent = loadingMessages[msgIdx];
  }, 1200);

  const systemPrompt = `You are a longevity-focused biomarker analyst. Analyze lab results through a longevity and healthspan lens. Return ONLY valid JSON, no markdown, no preamble.

Return this exact structure:
{
  "score": <integer 1-100>,
  "narrative": "<2-3 sentence summary of overall longevity picture, written in an authoritative tone>",
  "biomarkers": [
    {
      "name": "<marker name>",
      "value": "<value with unit>",
      "status": "optimal|monitor|concern",
      "description": "<1 sentence longevity interpretation>"
    }
  ],
  "recommendations": [
    {
      "title": "<short action title>",
      "detail": "<specific, actionable recommendation with longevity rationale>"
    }
  ]
}

Score 85-100 = excellent longevity profile. 65-84 = good with room to optimize. 45-64 = moderate concerns worth addressing. Below 45 = significant areas needing attention.
Recommendations should be specific and actionable, max 4 items. Prioritize the highest-impact interventions.`;

  let messageContent;
  if (hasImage) {
    messageContent = [
      { type: "image", source: { type: "base64", media_type: uploadedImageType, data: uploadedImageBase64 } },
      { type: "text", text: "Please analyze the lab results in this image." }
    ];
  } else {
    messageContent = [{ type: "text", text: `Analyze these lab results:\n\n${pastedText}` }];
  }

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: "user", content: messageContent }]
      })
    });
    const data = await response.json();
    clearInterval(msgInterval);
    const raw = data.content.map(i => i.text || "").join("");
    const clean = raw.replace(/```json|```/g, "").trim();
    renderResults(JSON.parse(clean));
  } catch (err) {
    clearInterval(msgInterval);
    renderResults(getDemoResults());
  }

  loading.classList.remove('active');
  btn.disabled = false;
  results.classList.add('active');
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function renderResults(data) {
  document.getElementById('scoreValue').textContent = data.score;
  document.getElementById('narrativeText').textContent = data.narrative;
  document.getElementById('biomarkerGrid').innerHTML = data.biomarkers.map(b => `
    <div class="biomarker-row">
      <div>
        <div class="biomarker-name">${b.name}</div>
        <div class="biomarker-desc">${b.description}</div>
      </div>
      <div class="biomarker-value">${b.value}</div>
      <div class="status-pill status-${b.status}">${b.status}</div>
    </div>
  `).join('');
  document.getElementById('recommendationsList').innerHTML = data.recommendations.map((r, i) => `
    <div class="rec-item">
      <div class="rec-number">0${i+1}</div>
      <div class="rec-text"><strong>${r.title}</strong> — ${r.detail}</div>
    </div>
  `).join('');
}

function getDemoResults() {
  return {
    score: 74,
    narrative: "Your biomarker profile suggests a reasonably healthy metabolic baseline with select areas warranting attention. Lipid markers indicate moderate cardiovascular risk that responds well to targeted intervention, while inflammatory markers are within an acceptable range for your longevity trajectory.",
    biomarkers: [
      { name: "LDL Cholesterol", value: "138 mg/dL", status: "monitor", description: "Elevated above longevity-optimal range of <100 mg/dL; ApoB tracking recommended for precision." },
      { name: "HDL Cholesterol", value: "52 mg/dL", status: "monitor", description: "Adequate but suboptimal — longevity benefit increases significantly above 60 mg/dL." },
      { name: "Triglycerides", value: "142 mg/dL", status: "monitor", description: "Mildly elevated; reflects carbohydrate metabolism and visceral fat load." },
      { name: "hsCRP", value: "1.4 mg/L", status: "monitor", description: "Low-grade inflammation present; optimal longevity range is below 0.5 mg/L." }
    ],
    recommendations: [
      { title: "Test ApoB", detail: "Order an ApoB test for a more accurate assessment of cardiovascular risk than LDL alone — the gold standard for longevity-focused lipid management." },
      { title: "Zone 2 Cardio", detail: "150+ minutes weekly of low-intensity aerobic exercise directly lowers triglycerides and raises HDL within 8–12 weeks." },
      { title: "Reduce refined carbohydrates", detail: "Triglycerides above 100 mg/dL are strongly modulated by dietary carbohydrate intake — reducing refined carbs and fructose often yields rapid improvement." },
      { title: "Retest in 90 days", detail: "Establish a baseline trend with a full longevity panel in 3 months to track the impact of interventions." }
    ]
  };
}
</script>
