// ── On page load: check for Stripe redirect or cancellation ─────────────────
(function() {
  const params     = new URLSearchParams(window.location.search);
  const sessionId  = params.get('session_id');
  const cancelled  = params.get('cancelled');

  if (sessionId) {
    // Clean URL without reloading
    history.replaceState(null, '', '/analyze');
    handlePostPayment(sessionId);
  } else if (cancelled) {
    history.replaceState(null, '', '/analyze');
    // Show a subtle notice — user cancelled at Stripe
    const notice = document.createElement('div');
    notice.style.cssText = 'padding:12px 16px;background:rgba(200,169,110,0.08);border:1px solid rgba(200,169,110,0.15);border-radius:3px;font-family:DM Mono,monospace;font-size:11px;letter-spacing:0.04em;color:var(--gold);margin-bottom:16px;';
    notice.textContent   = 'Checkout cancelled — your analysis is still available below.';
    document.querySelector('.tool-body').prepend(notice);

    // Restore free results if we have them in sessionStorage
    const stored = sessionStorage.getItem('al_lab_data');
    if (stored) {
      // Don't re-run — just restore the upgrade state if results were showing
    }
  }
})();
</script>
