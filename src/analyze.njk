---
layout: layouts/base.njk
title: "agelesslabs.ai — AI Biomarker Interpreter"
description: "Upload your lab results and get an AI-powered longevity biomarker analysis. Free, instant, no account required."
---

{% block head %}
<style>
  /* Analyze page overrides & tool-specific styles */

  body { overflow-x: hidden; }

  body::before {
    background:
      radial-gradient(ellipse 60% 40% at 20% 20%, rgba(181,201,160,0.03) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 80% 80%, rgba(200,169,110,0.02) 0%, transparent 60%);
  }

  .container { max-width: 860px; padding: 0 24px; }

  .badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 2px;
  }

  .hero { display: block; padding: 0; margin-bottom: 56px; animation: fadeUp 0.8s ease both; }
  .hero-eyebrow { margin-bottom: 20px; }
  h1 em { color: var(--green); }
  .hero-sub { max-width: 600px; margin-bottom: 0; }

  /* Tool card */
  .tool-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 48px;
    animation: fadeUp 0.8s 0.1s ease both;
  }

  .tool-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg3);
  }

  .tool-header-left { display: flex; align-items: center; gap: 10px; }

  .tool-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
    animation: pulse 2s infinite;
  }

  .tool-title {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .tool-body { padding: 28px; }

  .input-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }

  textarea {
    width: 100%;
    height: 180px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 16px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 300;
    line-height: 1.7;
    resize: vertical;
    outline: none;
    transition: border-color 0.15s;
  }
  textarea:focus { border-color: rgba(181,201,160,0.3); }
  textarea::placeholder { color: var(--text-muted); opacity: 0.5; }

  .example-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .example-tag {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    padding: 5px 10px;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .example-tag:hover { color: var(--green); border-color: rgba(181,201,160,0.3); }

  .analyze-btn {
    width: 100%;
    padding: 16px;
    background: var(--green);
    color: var(--bg);
    border: none;
    border-radius: 3px;
    font-family: 'Red Hat Display', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .analyze-btn:hover { background: var(--green-bright); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(181,201,160,0.2); }
  .analyze-btn:active { transform: translateY(0); }
  .analyze-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* Loading state */
  .loading { display: none; padding: 40px 28px; text-align: center; }
  .loading.active { display: block; }

  .loading-bar {
    height: 2px;
    background: var(--bg3);
    border-radius: 1px;
    overflow: hidden;
    margin-bottom: 20px;
    position: relative;
  }
  .loading-bar-inner {
    height: 100%;
    width: 40%;
    background: var(--green);
    border-radius: 1px;
    animation: scan 1.4s ease-in-out infinite;
  }
  .loading-text {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* Results */
  .results { display: none; border-top: 1px solid var(--border); }
  .results.active { display: block; }

  .results-header {
    padding: 20px 28px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .results-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .longevity-score { display: flex; align-items: baseline; gap: 4px; }
  .score-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-right: 8px;
  }
  .score-value {
    font-size: 36px;
    font-weight: 700;
    color: var(--green);
    line-height: 1;
  }
  .score-max {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
  }

  .results-body { padding: 28px; }

  .result-section { margin-bottom: 32px; animation: fadeUp 0.5s ease both; }
  .result-section:nth-child(2) { animation-delay: 0.1s; }
  .result-section:nth-child(3) { animation-delay: 0.2s; }
  .result-section:nth-child(4) { animation-delay: 0.3s; }

  .result-section-title {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--green);
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .biomarker-grid { display: grid; gap: 8px; }

  .biomarker-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
  }
  .biomarker-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .biomarker-desc {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    font-weight: 300;
  }
  .biomarker-value {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text);
    white-space: nowrap;
  }

  .status-pill {
    font-family: 'DM Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
  }
  .status-optimal { color: var(--green); background: var(--green-dim); border: 1px solid var(--border); }
  .status-monitor { color: var(--gold); background: rgba(200,169,110,0.08); border: 1px solid rgba(200,169,110,0.15); }
  .status-concern { color: #c87060; background: rgba(200,112,96,0.08); border: 1px solid rgba(200,112,96,0.15); }

  .narrative {
    font-size: 15px;
    color: var(--text);
    line-height: 1.8;
    font-weight: 300;
    padding: 20px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  .recommendations { display: grid; gap: 8px; }
  .rec-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 16px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
  }
  .rec-number {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--green);
    opacity: 0.5;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .rec-text { font-size: 14px; color: var(--text-dim); line-height: 1.6; font-weight: 300; }
  .rec-text strong { color: var(--white); font-weight: 500; }

  /* Upgrade CTA */
  .upgrade-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px;
    background: rgba(181,201,160,0.03);
    border: 1px solid rgba(181,201,160,0.15);
    border-radius: 3px;
    margin-top: 24px;
  }
  .cta-text h3 { font-size: 16px; font-weight: 600; color: var(--white); margin-bottom: 6px; letter-spacing: -0.01em; }
  .cta-text p { font-size: 13px; color: var(--text-dim); line-height: 1.6; font-weight: 300; }
  .cta-btn {
    flex-shrink: 0;
    padding: 12px 24px;
    background: var(--gold);
    color: var(--bg);
    border: none;
    border-radius: 2px;
    font-family: 'Red Hat Display', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .cta-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }

  .disclaimer {
    margin-top: 24px;
    padding: 14px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    line-height: 1.6;
    border-top: 1px solid var(--border);
    opacity: 0.6;
  }

  /* Tabs */
  .input-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }
  .tab-btn {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    background: transparent;
    border: none;
    padding: 12px 20px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.15s;
  }
  .tab-btn:hover { color: var(--text-dim); }
  .tab-btn.active { color: var(--green); border-bottom-color: var(--green); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* Upload zone */
  .upload-zone {
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--bg3);
    position: relative;
  }
  .upload-zone:hover, .upload-zone.dragover {
    border-color: rgba(181,201,160,0.3);
    background: rgba(181,201,160,0.03);
  }
  .upload-zone input[type="file"] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
  .upload-icon {
    width: 40px; height: 40px; margin: 0 auto 16px;
    border: 1px solid var(--border); border-radius: 2px;
    display: flex; align-items: center; justify-content: center; opacity: 0.6;
  }
  .upload-icon svg { width: 18px; height: 18px; stroke: var(--green); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .upload-title { font-size: 15px; font-weight: 500; color: var(--white); margin-bottom: 8px; letter-spacing: -0.01em; }
  .upload-sub { font-size: 13px; font-weight: 300; color: var(--text-dim); }
  .upload-status {
    margin-top: 16px; padding: 12px 16px;
    background: rgba(181,201,160,0.04); border: 1px solid rgba(181,201,160,0.12); border-radius: 3px;
    font-size: 13px; font-weight: 300; color: var(--green);
    display: none; text-align: left;
  }
  .upload-status.active { display: block; }

  @media (max-width: 600px) {
    .upgrade-cta { flex-direction: column; }
    .biomarker-row { grid-template-columns: 1fr; }
    .results-header { flex-direction: column; align-items: flex-start; gap: 12px; }
  }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
{% endblock %}

{% block header %}
  <header style="padding:32px 0 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);margin-bottom:64px;">
    <a href="/" class="logo">
      <span class="ageless">ageless</span><span class="labs">labs</span><span class="dot">.</span><span class="ai">ai</span>
    </a>
    <div class="badge">Beta — Free Interpreter</div>
  </header>
{% endblock %}

{% block content %}
  <section class="hero">
    <div class="hero-eyebrow">AI Biomarker Analysis</div>
    <h1>Understand what your<br><em>labs reveal</em> about<br>how long you'll live.</h1>
    <p class="hero-sub">Upload your lab results or paste the text. Our AI interprets each biomarker through a longevity lens — flagging what matters, explaining what it means, and telling you what to do next.</p>
  </section>

  <div class="tool-card">
    <div class="tool-header">
      <div class="tool-header-left">
        <div class="tool-dot"></div>
        <span class="tool-title">Biomarker Interpreter</span>
      </div>
