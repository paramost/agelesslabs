---
layout: base.njk
analyzePage: true
title: "agelesslabs.ai — AI Biomarker Interpreter"
description: "Upload your lab results and get an AI-powered longevity biomarker analysis. Free, instant, no account required."
---

<style>
/* Analyze page overrides & tool-specific styles */
body { overflow-x: hidden; }
body::before {
  background:
    radial-gradient(ellipse 60% 40% at 20% 20%, rgba(181,201,160,0.03) 0%, transparent 60%),
    radial-gradient(ellipse 40% 60% at 80% 80%, rgba(200,169,110,0.02) 0%, transparent 60%);
}
.hero { display: block; padding: 28px 0 0; margin-bottom: 56px; animation: fadeUp 0.8s ease both; }
.hero-eyebrow { margin-bottom: 20px; }
h1 em { color: var(--green); }
.hero-sub { max-width: 600px; margin-bottom: 0; }

/* Tool card */
.tool-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; overflow: hidden; margin-bottom: 48px; animation: fadeUp 0.8s 0.1s ease both; }
.tool-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; background: var(--bg3); }
.tool-header-left { display: flex; align-items: center; gap: 10px; }
.tool-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px var(--green); animation: pulse 2s infinite; }
.tool-title { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--text-muted); text-transform: uppercase; }
.tool-body { padding: 28px; }
.input-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.15em; color: var(--text-muted); text-transform: uppercase; display: block; margin-bottom: 12px; }
textarea { width: 100%; height: 180px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; padding: 16px; color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 300; line-height: 1.7; resize: vertical; outline: none; transition: border-color 0.15s; }
textarea:focus { border-color: rgba(181,201,160,0.3); }
textarea::placeholder { color: var(--text-muted); opacity: 0.5; }
.example-tags { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
.example-tag { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); background: transparent; border: 1px solid var(--border); padding: 5px 10px; border-radius: 2px; cursor: pointer; transition: all 0.15s; }
.example-tag:hover { color: var(--green); border-color: rgba(181,201,160,0.3); }
.analyze-btn { width: 100%; padding: 16px; background: var(--green); color: var(--bg); border: none; border-radius: 3px; font-family: 'Red Hat Display', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
.analyze-btn:hover { background: var(--green-bright); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(181,201,160,0.2); }
.analyze-btn:active { transform: translateY(0); }
.analyze-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

/* Loading state */
.loading { display: none; padding: 40px 28px; text-align: center; }
.loading.active { display: block; }
.loading-bar { height: 2px; background: var(--bg3); border-radius: 1px; overflow: hidden; margin-bottom: 20px; position: relative; }
.loading-bar-inner { height: 100%; width: 40%; background: var(--green); border-radius: 1px; animation: scan 1.4s ease-in-out infinite; }
.loading-text { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--text-muted); text-transform: uppercase; }

/* Free results */
.results { display: none; border-top: 1px solid var(--border); }
.results.active { display: block; }
.results-header { padding: 20px 28px; background: var(--bg3); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 16px; }
.results-title { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.2em; color: var(--text-muted); text-transform: uppercase; }
.longevity-score { display: flex; align-items: baseline; gap: 4px; }
.score-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.15em; color: var(--text-muted); text-transform: uppercase; margin-right: 8px; }
.score-value { font-size: 36px; font-weight: 700; color: var(--green); line-height: 1; }
.score-max { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text-muted); }
.results-body { padding: 28px; }
.result-section { margin-bottom: 32px; animation: fadeUp 0.5s ease both; }
.result-section:nth-child(2) { animation-delay: 0.1s; }
.result-section:nth-child(3) { animation-delay: 0.2s; }
.result-section:nth-child(4) { animation-delay: 0.3s; }
.result-section-title { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.2em; color: var(--green); text-transform: uppercase; margin-bottom: 16px; opacity: 0.7; }
.biomarker-grid { display: grid; gap: 8px; }
.biomarker-row { display: grid; grid-template-columns: 1fr auto auto; gap: 16px; align-items: center; padding: 14px 16px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; }
.biomarker-name { font-size: 14px; font-weight: 500; color: var(--white); margin-bottom: 4px; letter-spacing: -0.01em; }
.biomarker-desc { font-size: 12px; color: var(--text-dim); line-height: 1.5; font-weight: 400; }
.biomarker-value { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text); white-space: nowrap; }
.status-pill { font-family: 'DM Mono', monospace; font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 2px; white-space: nowrap; }
.status-optimal { color: var(--green); background: var(--green-dim); border: 1px solid var(--border); }
.status-monitor { color: var(--gold); background: rgba(200,169,110,0.08); border: 1px solid rgba(200,169,110,0.15); }
.status-concern { color: #c87060; background: rgba(200,112,96,0.08); border: 1px solid rgba(200,112,96,0.15); }
.narrative { font-size: 15px; color: var(--text); line-height: 1.8; font-weight: 400; padding: 20px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; }
.recommendations { display: grid; gap: 8px; }
.rec-item { display: flex; gap: 16px; align-items: flex-start; padding: 16px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; }
.rec-number { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--green); opacity: 0.5; flex-shrink: 0; margin-top: 2px; }
.rec-text { font-size: 14px; color: var(--text-dim); line-height: 1.6; font-weight: 400; }
.rec-text strong { color: var(--white); font-weight: 500; }

/* Upgrade CTA */
.upgrade-cta { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 24px; background: rgba(181,201,160,0.03); border: 1px solid rgba(181,201,160,0.15); border-radius: 3px; margin-top: 24px; }
.cta-text h3 { font-size: 16px; font-weight: 600; color: var(--white); margin-bottom: 6px; letter-spacing: -0.01em; }
.cta-text p { font-size: 13px; color: var(--text-dim); line-height: 1.6; font-weight: 400; }
.cta-btn { flex-shrink: 0; padding: 12px 24px; background: var(--gold); color: var(--bg); border: none; border-radius: 2px; font-family: 'Red Hat Display', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; white-space: nowrap; transition: all 0.2s; }
.cta-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
.cta-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.disclaimer { margin-top: 24px; padding: 14px 16px; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.04em; color: var(--text-muted); line-height: 1.6; border-top: 1px solid var(--border); opacity: 0.6; }

/* Tabs */
.input-tabs { display: flex; border-bottom: 1px solid var(--border); margin-bottom: 24px; }
.tab-btn { font-family: 'Red Hat Display', sans-serif; font-size: 13px; font-weight: 500; color: var(--text-muted); background: transparent; border: none; padding: 12px 20px; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; }
.tab-btn:hover { color: var(--text-dim); }
.tab-btn.active { color: var(--green); border-bottom-color: var(--green); }
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* Upload zone */
.upload-zone { border: 1px solid var(--border); border-radius: 3px; padding: 48px 24px; text-align: center; cursor: pointer; transition: all 0.2s; background: var(--bg3); position: relative; }
.upload-zone:hover, .upload-zone.dragover { border-color: rgba(181,201,160,0.3); background: rgba(181,201,160,0.03); }
.upload-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.upload-icon { width: 40px; height: 40px; margin: 0 auto 16px; border: 1px solid var(--border); border-radius: 2px; display: flex; align-items: center; justify-content: center; opacity: 0.6; }
.upload-icon svg { width: 18px; height: 18px; stroke: var(--green); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.upload-title { font-size: 15px; font-weight: 500; color: var(--white); margin-bottom: 8px; letter-spacing: -0.01em; }
.upload-sub { font-size: 13px; font-weight: 400; color: var(--text-dim); }
.upload-status { margin-top: 16px; padding: 12px 16px; background: rgba(181,201,160,0.04); border: 1px solid rgba(181,201,160,0.12); border-radius: 3px; font-size: 13px; font-weight: 400; color: var(--green); display: none; text-align: left; }
.upload-status.active { display: block; }

/* ── PAID REPORT ─────────────────────────────────────────── */
.paid-report { display: none; border-top: 1px solid var(--border); }
.paid-report.active { display: block; }

.paid-header { padding: 20px 28px; background: linear-gradient(135deg, rgba(181,201,160,0.06) 0%, rgba(200,169,110,0.04) 100%); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
.paid-header-left { display: flex; flex-direction: column; gap: 4px; }
.paid-badge { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 4px; }
.paid-title { font-size: 18px; font-weight: 600; color: var(--white); letter-spacing: -0.02em; }
.paid-header-score { display: flex; align-items: baseline; gap: 4px; }

.paid-body { padding: 28px; display: flex; flex-direction: column; gap: 36px; }

/* Paid biomarker rows — richer than free */
.paid-biomarker-row { padding: 18px 20px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; }
.paid-bm-top { display: grid; grid-template-columns: 1fr auto auto; gap: 16px; align-items: start; margin-bottom: 10px; }
.paid-bm-name { font-size: 15px; font-weight: 600; color: var(--white); letter-spacing: -0.01em; }
.paid-bm-desc { font-size: 13px; color: var(--text-dim); line-height: 1.6; margin-bottom: 8px; }
.paid-bm-mechanism { font-size: 12px; color: var(--text-muted); line-height: 1.5; font-style: italic; }
.paid-ranges { display: flex; gap: 16px; margin-top: 10px; flex-wrap: wrap; }
.paid-range-item { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.04em; color: var(--text-muted); }
.paid-range-item span { color: var(--text-dim); }

/* Marker interactions */
.interaction-card { padding: 18px 20px; background: var(--bg3); border-radius: 3px; }
.interaction-card.severity-concern { border: 1px solid rgba(200,112,96,0.25); }
.interaction-card.severity-monitor { border: 1px solid rgba(200,169,110,0.2); }
.interaction-card.severity-note { border: 1px solid var(--border); }
.interaction-title { font-size: 14px; font-weight: 600; color: var(--white); margin-bottom: 6px; letter-spacing: -0.01em; }
.interaction-markers { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
.interaction-marker-tag { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; padding: 3px 8px; border-radius: 2px; background: rgba(181,201,160,0.07); border: 1px solid rgba(181,201,160,0.15); color: var(--green); }
.interaction-insight { font-size: 13px; color: var(--text-dim); line-height: 1.65; }

/* Action plan */
.action-item { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: start; padding: 18px 20px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; }
.action-rank { font-family: 'DM Mono', monospace; font-size: 22px; font-weight: 700; color: var(--green); opacity: 0.3; line-height: 1; padding-top: 2px; min-width: 28px; }
.action-body {}
.action-title { font-size: 15px; font-weight: 600; color: var(--white); margin-bottom: 4px; letter-spacing: -0.01em; }
.action-meta { display: flex; gap: 12px; margin-bottom: 8px; }
.action-impact { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; padding: 2px 7px; border-radius: 2px; }
.action-impact.high { color: var(--green); background: rgba(181,201,160,0.08); border: 1px solid rgba(181,201,160,0.2); }
.action-impact.medium { color: var(--gold); background: rgba(200,169,110,0.08); border: 1px solid rgba(200,169,110,0.15); }
.action-impact.low { color: var(--text-muted); background: transparent; border: 1px solid var(--border); }
.action-timeline { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.08em; color: var(--text-muted); padding-top: 3px; }
.action-detail { font-size: 13px; color: var(--text-dim); line-height: 1.65; }

/* Missing tests / affiliate */
.missing-test-item { padding: 16px 20px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
.missing-test-left {}
.missing-test-name { font-size: 14px; font-weight: 600; color: var(--white); margin-bottom: 4px; letter-spacing: -0.01em; }
.missing-test-reason { font-size: 12px; color: var(--text-dim); line-height: 1.5; }
.missing-test-priority { font-family: 'DM Mono', monospace; font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; padding: 2px 7px; border-radius: 2px; display: inline-block; margin-bottom: 6px; }
.missing-test-priority.high { color: #c87060; background: rgba(200,112,96,0.08); border: 1px solid rgba(200,112,96,0.15); }
.missing-test-priority.medium { color: var(--gold); background: rgba(200,169,110,0.08); border: 1px solid rgba(200,169,110,0.15); }
.missing-test-links { display: flex; gap: 8px; flex-shrink: 0; flex-wrap: wrap; }
.affiliate-link { font-family: 'Red Hat Display', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; padding: 7px 14px; border-radius: 2px; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
.affiliate-link.ulta { color: var(--green); border: 1px solid rgba(181,201,160,0.3); background: rgba(181,201,160,0.04); }
.affiliate-link.ulta:hover { background: rgba(181,201,160,0.1); }
.affiliate-link.function { color: var(--gold); border: 1px solid rgba(200,169,110,0.3); background: rgba(200,169,110,0.04); }
.affiliate-link.function:hover { background: rgba(200,169,110,0.1); }
.affiliate-link.omegaquant { color: var(--text-dim); border: 1px solid var(--border); background: transparent; }
.affiliate-link.omegaquant:hover { color: var(--white); }
.affiliate-link.pending { display: none; }

/* Comprehensive panel CTA */
.panel-cta { padding: 24px; background: rgba(200,169,110,0.04); border: 1px solid rgba(200,169,110,0.2); border-radius: 3px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
.panel-cta-text h4 { font-size: 16px; font-weight: 600; color: var(--white); margin-bottom: 6px; letter-spacing: -0.01em; }
.panel-cta-text p { font-size: 13px; color: var(--text-dim); line-height: 1.6; }
.panel-cta-btn { flex-shrink: 0; padding: 12px 24px; background: var(--gold); color: var(--bg); border: none; border-radius: 2px; font-family: 'Red Hat Display', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; text-decoration: none; white-space: nowrap; transition: all 0.2s; display: inline-block; }
.panel-cta-btn:hover { filter: brightness(1.1); }

/* PDF download */
.pdf-bar { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; gap: 16px; flex-wrap: wrap; }
.pdf-bar-text { font-size: 13px; color: var(--text-dim); }
.pdf-btn { padding: 9px 20px; background: transparent; border: 1px solid rgba(181,201,160,0.3); border-radius: 2px; font-family: 'Red Hat Display', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--green); cursor: pointer; transition: all 0.15s; }
.pdf-btn:hover { background: rgba(181,201,160,0.06); }

/* Payment loading / verify state */
.payment-verify { display: none; padding: 48px 28px; text-align: center; border-top: 1px solid var(--border); }
.payment-verify.active { display: block; }
.payment-verify-text { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--text-muted); text-transform: uppercase; margin-top: 16px; }

/* Print styles */
@media print {
  nav, footer, .tool-body, .loading, .results, .payment-verify, .upgrade-cta, .pdf-bar, .hero { display: none !important; }
  .paid-report { display: block !important; border: none !important; }
  .tool-card { border: none !important; box-shadow: none !important; }
  body { background: white !important; color: black !important; }
  .paid-header { background: #f8f8f8 !important; }
  .paid-badge, .paid-title, .action-title, .paid-bm-name, .interaction-title, .missing-test-name { color: black !important; }
  .paid-bm-desc, .action-detail, .interaction-insight, .missing-test-reason { color: #333 !important; }
  .score-value { color: #2d6a2d !important; }
}

@media (max-width: 600px) {
  .upgrade-cta, .panel-cta { flex-direction: column; }
  .paid-bm-top, .biomarker-row { grid-template-columns: 1fr; }
  .results-header, .paid-header { flex-direction: column; align-items: flex-start; gap: 12px; }
  .action-item { grid-template-columns: 1fr; }
  .action-rank { font-size: 14px; }
}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<section class="hero">
  <div class="hero-eyebrow">AI Biomarker Analysis</div>
  <h1>Understand what your<br><em>labs reveal</em> about<br>how long you'll live.</h1>
  <p class="hero-sub">Upload your lab results or paste the text. Our AI interprets each biomarker through a longevity lens — flagging what matters, explaining what it means, and telling you what to do next.</p>
</section>

<div class="tool-card">

  <!-- Input / free tool -->
  <div class="tool-header">
    <div class="tool-header-left">
      <div class="tool-dot"></div>
      <span class="tool-title">Biomarker Interpreter</span>
    </div>
    <span class="tool-title" style="font-size:10px;">Free · No account required</span>
  </div>

  <div class="tool-body">
    <div class="input-tabs">
      <button class="tab-btn active" onclick="switchTab('upload')">Upload File</button>
      <button class="tab-btn" onclick="switchTab('paste')">Paste Text</button>
    </div>

    <div class="tab-panel active" id="tab-upload">
      <div class="upload-zone" id="uploadZone">
        <input type="file" id="fileInput" accept=".pdf,.jpg,.jpeg,.png,.webp" onchange="handleFileSelect(event)">
        <div class="upload-icon">
          <svg viewBox="0 0 24 24">
            <path d="M12 15V3m0 0L8 7m4-4 4 4M2 17l.621 2.485A2 2 0 0 0 4.561 21h14.878a2 2 0 0 0 1.94-1.515L22 17"/>
          </svg>
        </div>
        <div class="upload-title">Upload your lab results</div>
        <div class="upload-sub">PDF, JPG, or PNG — drag and drop or click to browse</div>
      </div>
      <div class="upload-status" id="uploadStatus"></div>
    </div>

    <div class="tab-panel" id="tab-paste">
      <label class="input-label" for="labInput">Paste your lab results</label>
      <textarea id="labInput" placeholder="Example:
Glucose: 94 mg/dL
HbA1c: 5.2%
Total Cholesterol: 188 mg/dL
LDL: 112 mg/dL
HDL: 58 mg/dL
Triglycerides: 89 mg/dL
hsCRP: 0.8 mg/L
Vitamin D: 38 ng/mL
TSH: 1.8 mIU/L
Ferritin: 45 ng/mL"></textarea>
      <div class="example-tags">
        <span class="input-label" style="margin:0;line-height:2;">Try an example:</span>
        <button class="example-tag" onclick="loadExample('metabolic')">Metabolic Panel</button>
        <button class="example-tag" onclick="loadExample('lipid')">Lipid Panel</button>
        <button class="example-tag" onclick="loadExample('longevity')">Full Longevity Panel</button>
      </div>
    </div>

    <button class="analyze-btn" id="analyzeBtn" onclick="analyzeLabResults()" style="margin-top:24px;">
      Analyze My Biomarkers
    </button>
    <div id="analyzeError" style="display:none;margin-top:14px;padding:12px 16px;background:rgba(200,112,96,0.08);border:1px solid rgba(200,112,96,0.2);border-radius:3px;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.04em;color:#c87060;"></div>
  </div>

  <!-- Loading -->
  <div class="loading" id="loadingState">
    <div class="loading-bar"><div class="loading-bar-inner"></div></div>
    <div class="loading-text" id="loadingText">Interpreting biomarkers...</div>
  </div>

  <!-- Free results -->
  <div class="results" id="resultsSection">
    <div class="results-header">
      <div class="results-title">Your Longevity Analysis</div>
      <div class="longevity-score">
        <span class="score-label">Longevity Score</span>
        <span class="score-value" id="scoreValue">—</span>
        <span class="score-max">/100</span>
      </div>
    </div>
    <div class="results-body">
      <div class="result-section">
        <div class="result-section-title">Overall Assessment</div>
        <div class="narrative" id="narrativeText"></div>
      </div>
      <div class="result-section">
        <div class="result-section-title">Biomarker Breakdown</div>
        <div class="biomarker-grid" id="biomarkerGrid"></div>
      </div>
      <div class="result-section">
        <div class="result-section-title">Priority Recommendations</div>
        <div class="recommendations" id="recommendationsList"></div>
      </div>
      <div class="upgrade-cta">
