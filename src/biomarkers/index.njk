      <div class="bmi-card-footer">
        <span class="bmi-card-optimal">Optimal: 120–180 ng/mL (age-dependent)</span>
        <span class="bmi-card-arrow">&#8594;</span>
      </div>
    </a>

    <a href="/biomarkers/cortisol" class="bmi-card available">
      <div class="bmi-card-name">Cortisol</div>
      <div class="bmi-card-aka">Serum Cortisol</div>
      <div class="bmi-card-desc">Chronically elevated cortisol accelerates biological aging, suppresses immunity, and promotes visceral fat accumulation.</div>
      <div class="bmi-card-footer">
        <span class="bmi-card-optimal">Optimal (AM): 10–18 µg/dL</span>
        <span class="bmi-card-arrow">&#8594;</span>
      </div>
    </a>

