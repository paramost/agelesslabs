<tr><th>Category</th><th>Key markers included</th></tr>
</thead>
<tbody>
<tr>
<td>Cardiovascular</td>
<td><a href="/biomarkers/apob">ApoB</a>, LDL-C, HDL-C, triglycerides, LDL particle analysis, <a href="/biomarkers/hscrp">hsCRP</a></td>
</tr>
<tr>
<td>Metabolic</td>
<td><a href="/biomarkers/hba1c">HbA1c</a>, fasting glucose, <a href="/biomarkers/alt-ast">ALT/AST</a>, <a href="/biomarkers/ggt">GGT</a>, insulin (base panel)</td>
</tr>
<tr>
<td>Hormonal</td>
<td>Total + free testosterone, <a href="/biomarkers/estradiol">estradiol</a>, <a href="/biomarkers/progesterone">progesterone</a>, <a href="/biomarkers/shbg">SHBG</a>, <a href="/biomarkers/dhea-s">DHEA-S</a>, <a href="/biomarkers/igf-1">IGF-1</a></td>
</tr>
<tr>
<td>Thyroid</td>
