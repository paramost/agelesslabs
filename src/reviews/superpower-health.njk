<td><a href="/biomarkers/vitamin-d">Vitamin D</a>, <a href="/biomarkers/vitamin-b12">B12</a>, <a href="/biomarkers/ferritin">ferritin</a>, folate, zinc</td>
</tr>
<tr>
<td>Kidney / Liver</td>
<td><a href="/biomarkers/creatinine-egfr">Creatinine/eGFR</a>, <a href="/biomarkers/albumin">albumin</a>, BUN, bilirubin, full CMP</td>
